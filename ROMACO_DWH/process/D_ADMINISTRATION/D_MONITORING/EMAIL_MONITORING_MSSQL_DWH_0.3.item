  <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="560" posY="120">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaFlex_1" show="false"/>
    <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE_START" value="ArrayList&lt;String> fehlermeldungen = new ArrayList&lt;String>();&#xA;fehlermeldungen.add(&quot;&lt;html>&lt;body>&lt;table align=\&quot;left\&quot; border=\&quot;1\&quot;>&lt;th>Time&lt;/th>&lt;th>Job&lt;/th>&lt;th>Context&lt;/th>&lt;th>Type&lt;/th>&lt;th>Component&lt;/th>&lt;th>Message&lt;/th>&quot;);"/>
    <elementParameter field="MEMO_JAVA" name="CODE_MAIN" value="fehlermeldungen.add(&quot;&lt;tr>&lt;td>&quot;+TalendDate.formatDate(&quot;dd.MM.yyyy HH:mm:ss&quot;,row5.moment)+&quot;&lt;/td>&lt;td>&quot;+ &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;row5.job+&quot;&lt;/td>&lt;td>&quot;+&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;row5.context+&quot;&lt;/td>&lt;td>&quot;+&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;row5.type+&quot;&lt;/td>&lt;td>&quot;+&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;row5.origin+&quot;&lt;/td>&lt;td>&quot;+&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;row5.message+&quot;&lt;/td>&lt;/tr>&quot;);"/>
    <elementParameter field="MEMO_JAVA" name="CODE_END" value="// end of the component, outside/closing the loop&#xA;fehlermeldungen.add(&quot;&lt;/table>&lt;/body>&lt;/html>&quot;) ;     &#xA;      &#xA;      globalMap.put(&quot;fehlermeldungen&quot;, fehlermeldungen);&#xA;"/>
    <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="import java.util.ArrayList;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Erstelle HTML Tabelle für Mailversand"/>
    <metadata connector="FLOW" name="tJavaFlex_1">
      <column comment="" key="false" length="19" name="moment" nullable="true" pattern="&quot;dd-MM-yyyy&quot;" precision="0" sourceType="DATETIME" type="id_Date" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="255" name="job" nullable="true" pattern="" precision="0" sourceType="VARCHAR" type="id_String" originalLength="-1" usefulColumn="true"/>
