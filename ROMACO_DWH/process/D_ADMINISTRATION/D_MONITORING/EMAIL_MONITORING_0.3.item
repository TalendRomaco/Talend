  <node componentName="tSendMail" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="800" posY="280">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tSendMail_1" show="false"/>
    <elementParameter field="TEXT" name="TO" value="context.RECEIVER"/>
    <elementParameter field="TEXT" name="FROM" value="context.SMTP_User"/>
    <elementParameter field="CHECK" name="NEED_PERSONAL_NAME" value="false"/>
    <elementParameter field="TEXT" name="PERSONAL_NAME" value="&quot;sender&quot;" show="false"/>
    <elementParameter field="TEXT" name="CC" value=""/>
    <elementParameter field="TEXT" name="BCC" value=""/>
    <elementParameter field="TEXT" name="SUBJECT" value="&quot;[Romaco DWH Monitoring]&quot;"/>
    <elementParameter field="MEMO_MESSAGE" name="MESSAGE" value="&quot;&lt;html>Sehr geehrte Damen und Herren,&#xD;&#xA;&lt;br>&lt;br>&#xD;&#xA;folgende Fehler sind beim heutigen Import in das Data Warehouse (MSSQL) aufgetreten.&#xD;&#xA;&lt;br>&lt;br>&#xD;&#xA;&quot;+((ArrayList&lt;String>)globalMap.get(&quot;fehlermeldungen&quot;)).toString().substring(1,((ArrayList&lt;String>)globalMap.get(&quot;fehlermeldungen&quot;)).toString().length() -1).replace(&quot;, &quot;, &quot;&quot;)  +&quot;&#xD;&#xA;&lt;br>&lt;br>&lt;br>&lt;br>&#xD;&#xA;Mit freundlichen Grüßen | With regards &#xD;&#xA;&lt;br>&#xD;&#xA;Data Warehouse Monitoring Client &lt;/html>&quot;"/>
    <elementParameter field="CHECK" name="CHECK_ATTACHMENT" value="true"/>
    <elementParameter field="TABLE" name="ATTACHMENTS"/>
    <elementParameter field="TABLE" name="HEADERS"/>
    <elementParameter field="TEXT" name="SMTP_HOST" value="context.SMTP_Host"/>
    <elementParameter field="TEXT" name="SMTP_PORT" value="context.SMTP_Port"/>
    <elementParameter field="CHECK" name="SSL" value="false"/>
    <elementParameter field="CHECK" name="STARTTLS" value="false"/>
    <elementParameter field="CLOSED_LIST" name="IMPORTANCE" value="Normal"/>
