    <elementParameter field="MEMO_MESSAGE" name="MESSAGE" value="&quot;&lt;html>Sehr geehrte Damen und Herren,&#xD;&#xA;&lt;br>&lt;br>&#xD;&#xA;folgende Fehler sind beim heutigen Import in das Data Warehouse (MSSQL) aufgetreten.&#xD;&#xA;&lt;br>&lt;br>&#xD;&#xA;&quot;+((ArrayList&lt;String>)globalMap.get(&quot;fehlermeldungen&quot;)).toString().substring(1).replaceFirst(&quot;]&quot;, &quot;&quot;).replace(&quot;, &quot;, &quot;&quot;) +&quot;&#xD;&#xA;&lt;br>&lt;br>&lt;br>&lt;br>&#xD;&#xA;Mit freundlichen Grüßen | With regards &#xD;&#xA;&lt;br>&#xD;&#xA;Data Warehouse Monitoring Client &lt;/html>&quot;"/>
