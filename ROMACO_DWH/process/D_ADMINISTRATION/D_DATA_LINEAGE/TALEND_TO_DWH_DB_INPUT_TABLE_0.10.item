    <elementParameter field="MEMO_JAVA" name="CODE" value="String sqlStatement_original = XML_Input_ergaenzt_4.Statement_bearbeitet;&#xA;String sqlStatement = XML_Input_ergaenzt_4.Statement_bearbeitet;&#xA;if (sqlStatement!=null &amp;&amp; !sqlStatement.equals(&quot;&quot;) &amp;&amp; !sqlStatement.contains(&quot;Leerer Kontext:&quot;)){&#xA;&#x9;try{&#xA;&#x9;&#x9;// Löse Formatfunktion auf&#x9;&#xA;&#x9;&#x9;Pattern pattern = Pattern.compile(&quot;format\\(&quot;, Pattern.CASE_INSENSITIVE);&#xA;&#x9;&#x9;Matcher matcher = pattern.matcher(sqlStatement);&#xA;&#x9;&#x9;while(matcher.find()){&#xA;&#x9;&#x9;&#x9;int startPosition = matcher.start();&#xA;&#x9;&#x9;&#x9;int currentPosition = startPosition+7;&#xA;&#x9;&#x9;&#x9;int brackets = 1;&#xA;&#x9;&#x9;&#x9;while (brackets>0){&#xA;&#x9;&#x9;&#x9;&#x9;if (sqlStatement.charAt(currentPosition)=='('){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;brackets++;&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;&#x9;if (sqlStatement.charAt(currentPosition)==')'){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;brackets--;&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;&#x9;currentPosition++;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;sqlStatement = sqlStatement.substring(0, startPosition) + &quot;formatted_column&quot; + sqlStatement.substring(currentPosition);&#xA;&#x9;&#x9;&#x9;matcher = pattern.matcher(sqlStatement);&#xA;&#x9;&#x9;}&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;// Parse Statement&#xA;&#x9;&#x9;Statement statement = CCJSqlParserUtil.parse(sqlStatement);&#xA;&#x9;&#x9;if (statement.getClass().toString().equals(&quot;class net.sf.jsqlparser.statement.select.Select&quot;)){&#xA;&#x9;&#x9;&#x9;// Ermittle Tabellen und schreibe diese in Liste&#xA;&#x9;&#x9;&#x9;Select selectStatement = (Select) statement;&#xA;&#x9;&#x9;&#x9;TablesNamesFinder tablesNamesFinder = new TablesNamesFinder();&#xA;&#x9;&#x9;&#x9;List&lt;String> tableList = tablesNamesFinder.getTableList(selectStatement);&#xA;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen=tableList.toString();&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = &quot;Parsing-Fehler: Kein Select-Statement&quot;;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;} catch (JSQLParserException e) {&#xA;&#x9;&#x9;// Schreibe Fehler in Konsole und in das entsprechende Feld&#xA;&#x9;&#x9;StringWriter sw = new StringWriter();&#xA;&#x9;&#x9;PrintWriter pw = new PrintWriter(sw);&#xA;&#x9;&#x9;e.printStackTrace(pw);&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = &quot;Parsing-Fehler: Ungültige Syntax oder nicht gehandhabter Spezialfall&quot;;&#xA;&#x9;} catch (ClassCastException e) {&#xA;&#x9;&#x9;// Schreibe Fehler in Konsole&#xA;&#x9;&#x9;StringWriter sw = new StringWriter();&#xA;&#x9;&#x9;PrintWriter pw = new PrintWriter(sw);&#xA;&#x9;&#x9;e.printStackTrace(pw);&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = sw.toString();&#xA;&#x9;}&#xA;}&#xA;XML_Input_ergaenzt_2.Projektname=XML_Input_ergaenzt.Projektname;&#xA;XML_Input_ergaenzt_2.Jobname_Technisch=XML_Input_ergaenzt.Jobname_Technisch;&#xA;XML_Input_ergaenzt_2.Komponente=XML_Input_ergaenzt.Komponente;"/>
