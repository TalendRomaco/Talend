    <elementParameter field="MEMO_JAVA" name="CODE" value="globalMap.put(&quot;Aktueller Job&quot;, Jobdaten_mit_Filter.Jobname_Technisch);&#xA;boolean exclude_row = false;&#xA;// Identifiziere Einträge, die sich in herauszufilterndem Ordner befinden&#xA;String folder = (String) globalMap.get(&quot;tFileList_1_CURRENT_FILEDIRECTORY&quot;);&#xA;String[] filter_Ordner = Jobdaten_mit_Filter.Filter_Ordner.split(&quot;,&quot;);&#xA;for (int i=0; i&lt;filter_Ordner.length; i++){&#xA;&#x9;if (folder.toLowerCase().contains(filter_Ordner[i].toLowerCase())) exclude_row = true;&#xA;}&#xA;// Identifiziere Einträge, die sich in herauszufilternder Datei befinden&#xA;String file = (String) globalMap.get(&quot;tFileList_1_CURRENT_FILE&quot;);&#xA;String[] filter_Jobname = Jobdaten_mit_Filter.Filter_Jobname.split(&quot;,&quot;);&#xA;for (int i=0; i&lt;filter_Jobname.length; i++){&#xA;&#x9;if (file.toLowerCase().contains(filter_Jobname[i].toLowerCase())) exclude_row = true;&#xA;}&#xA;Jobdaten_mit_Filter_2.Projektname = Jobdaten_mit_Filter.Projektname;&#xA;Jobdaten_mit_Filter_2.Subpfad = Jobdaten_mit_Filter.Subpfad;&#xA;Jobdaten_mit_Filter_2.Jobname = Jobdaten_mit_Filter.Jobname;&#xA;Jobdaten_mit_Filter_2.Version = Jobdaten_mit_Filter.Version;&#xA;Jobdaten_mit_Filter_2.Jobname_Technisch = Jobdaten_mit_Filter.Jobname_Technisch;&#xA;Jobdaten_mit_Filter_2.Filter = exclude_row;"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
