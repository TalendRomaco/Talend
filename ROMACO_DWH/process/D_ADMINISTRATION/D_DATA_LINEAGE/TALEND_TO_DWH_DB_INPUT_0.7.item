  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="552" posY="952">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="String statement_Aufgeloest = (String) globalMap.get(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente);&#xA;if(statement_Aufgeloest != null &amp;&amp; Komponente_mit_Kontexten.Kontext_Name != null) {&#xA;&#x9;// Prüfe, ob Kontextvariable leer oder null ist und ob diese im Statement verwendet wird&#xA;&#x9;if ((Komponente_mit_Kontexten.Kontext_Wert == null || Komponente_mit_Kontexten.Kontext_Wert.equals(&quot;&quot;)) &amp;&amp;  (statement_Aufgeloest.matches(&quot;[\\s\\S]*\&quot;[ +]*(\\([^()]*\\) *)?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ +][^\&quot;]*\&quot;&quot;) || statement_Aufgeloest.matches(&quot;[\\s\\S]*\&quot;[ +]*(\\([^()]*\\) *)?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ ]*$&quot;) || statement_Aufgeloest.matches(Komponente_mit_Kontexten.Kontext_Name))){&#xA;&#x9;&#x9;globalMap.put(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente, &quot;Leerer Kontext: &quot;+Komponente_mit_Kontexten.Kontext_Name);&#xA;&#x9;}&#xA;&#x9;else{&#xA;&#x9;&#x9;// Ersetze Kontextvariable inklusive die umgebenden, für Java-Syntax benötigten Zeichen, wenn diese am Anfang oder zwischen zwei Teilen des Statements verwendet wird&#xA;&#x9;&#x9;statement_Aufgeloest = statement_Aufgeloest.replaceAll(&quot;\&quot;[ +]*(\\([^()]*\\) *)?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ +][^\&quot;]*\&quot;&quot;, Komponente_mit_Kontexten.Kontext_Wert);&#xA;&#x9;&#x9;// Ersetze Kontextvariable inklusive die umgebenden, für Java-Syntax benötigten Zeichen, wenn diese am Ende eines Statements verwendet wird&#xA;&#x9;&#x9;statement_Aufgeloest = statement_Aufgeloest.replaceAll(&quot;\&quot;[ +]*(\\([^()]*\\) *)?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ ]*$&quot;, Komponente_mit_Kontexten.Kontext_Wert);&#xA;&#x9;&#x9;// Ersetze Kontextvariable, wenn diese das gesamte Statement ist&#xA;&#x9;&#x9;statement_Aufgeloest = statement_Aufgeloest.replaceAll(&quot;^&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;$&quot;, Komponente_mit_Kontexten.Kontext_Wert);&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;globalMap.put(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente, statement_Aufgeloest);&#xA;&#x9;}&#xA;}"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Ersetze Kontext in Statement"/>
    <metadata connector="FLOW" name="tJavaRow_1"/>
  </node>
