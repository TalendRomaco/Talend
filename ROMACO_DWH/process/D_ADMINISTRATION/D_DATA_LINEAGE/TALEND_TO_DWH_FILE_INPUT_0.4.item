  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="576" posY="592">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_3" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="String Dateiname = (String) globalMap.get(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente);&#xA;String Dateiname_original = Dateiname;&#xA;if(Dateiname != null &amp;&amp; Komponente_mit_Kontexten.Kontext_Name != null) {&#xA;&#x9;// Prüfe, ob Kontextvariable leer oder null ist und ob diese im Dateinamen verwendet wird&#xA;&#x9;if ((Komponente_mit_Kontexten.Kontext_Wert == null || Komponente_mit_Kontexten.Kontext_Wert.equals(&quot;&quot;)) &amp;&amp;  (Dateiname.matches(Komponente_mit_Kontexten.Kontext_Name) || Dateiname.matches(&quot;(\&quot;[^\&quot;])?[ +]?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ +][^\&quot;]*\&quot;&quot;))){&#xA;&#x9;&#x9;globalMap.put(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente, &quot;Leerer Kontext: &quot;+Komponente_mit_Kontexten.Kontext_Name);&#xA;&#x9;}&#xA;&#x9;else{&#xA;&#x9;&#x9;// Ersetze Kontextvariable, wenn diese der gesamte Dateiname ist&#xA;&#x9;&#x9;Dateiname = Dateiname.replaceAll(&quot;^&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;$&quot;, Matcher.quoteReplacement(Komponente_mit_Kontexten.Kontext_Wert));&#xA;&#x9;&#x9;if (!Dateiname.contains(&quot;(&quot;)){&#xA;&#x9;&#x9;&#x9;// Ersetze Kontextvariable inklusive die umgebenden, für Java-Syntax benötigten Zeichen, wenn diese am Anfang oder zwischen zwei Teilen des Dateinamens verwendet wird&#xA;&#x9;&#x9;&#x9;Dateiname = Dateiname.replaceAll(&quot;(\&quot;[^\&quot;])?[ +]?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ +][^\&quot;]*\&quot;&quot;, Matcher.quoteReplacement(Komponente_mit_Kontexten.Kontext_Wert));&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;// Ersetze Kontextvariable inklusive die umgebenden, für Java-Syntax benötigten Zeichen, wenn diese am Ende des Dateinamens verwendet wird&#xA;&#x9;&#x9;&#x9;Dateiname = Dateiname.replaceAll(&quot;(\&quot;[^\&quot;])?[ +]?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;( |$)&quot;, Matcher.quoteReplacement(Komponente_mit_Kontexten.Kontext_Wert));&#xA;&#x9;&#x9;}&#xA;&#x9;&#x9;// Speichere Kontext sofern in Dateinamen eingesetzt&#xA;&#x9;&#x9;if (!Dateiname.equals(Dateiname_original)){&#xA;&#x9;&#x9;&#x9;// Speichere Kontext als neue Variable, wenn bisher kein Kontext eingesetzt wurde&#xA;&#x9;&#x9;&#x9;if (globalMap.get(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente + &quot;Kontext&quot;)==null){&#xA;&#x9;&#x9;&#x9;&#x9;globalMap.put(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente + &quot;Kontext&quot;, Komponente_mit_Kontexten.Kontext_Wert);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;// Ergänze Kontext in bestehender Variable, wenn bereits ein Kontext eingesetzt wurde&#xA;&#x9;&#x9;&#x9;else{&#xA;&#x9;&#x9;&#x9;&#x9;globalMap.put(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente + &quot;Kontext&quot;, globalMap.get(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente + &quot;Kontext&quot;) + &quot;, &quot; + Komponente_mit_Kontexten.Kontext_Wert);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;}&#xA;&#x9;&#x9;globalMap.put(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente, Dateiname);&#xA;&#x9;}&#xA;}"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="import java.util.regex.Matcher;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Ersetze Kontext in Dateiname"/>
    <metadata connector="FLOW" name="tJavaRow_3"/>
  </node>
