  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="864" posY="200">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="String sqlStatement = XML_Input_ergaenzt_4.Statement_bearbeitet;&#xA;if (sqlStatement!=null &amp;&amp; !sqlStatement.equals(&quot;&quot;) &amp;&amp; !sqlStatement.contains(&quot;Leerer Kontext:&quot;) &amp;&amp; !sqlStatement.contains(&quot;MERGE&quot;) &amp;&amp; !sqlStatement.contains(&quot;EXECUTE&quot;) &amp;&amp; !sqlStatement.contains(&quot;globalMap&quot;)){&#xA;&#x9;try{&#xA;&#x9;&#x9;// Löse Formatfunktion auf&#xA;&#x9;&#x9;Pattern pattern = Pattern.compile(&quot;format\\(&quot;, Pattern.CASE_INSENSITIVE);&#xA;&#x9;&#x9;Matcher matcher = pattern.matcher(sqlStatement);&#xA;&#x9;&#x9;while(matcher.find()){&#xA;&#x9;&#x9;&#x9;int startPosition = matcher.start();&#xA;&#x9;&#x9;&#x9;int currentPosition = startPosition+7;&#xA;&#x9;&#x9;&#x9;int brackets = 1;&#xA;&#x9;&#x9;&#x9;while (brackets>0){&#xA;&#x9;&#x9;&#x9;&#x9;if (sqlStatement.charAt(currentPosition)=='('){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;brackets++;&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;&#x9;if (sqlStatement.charAt(currentPosition)==')'){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;brackets--;&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;&#x9;currentPosition++;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;sqlStatement = sqlStatement.substring(0, startPosition) + &quot;formatted_column&quot; + sqlStatement.substring(currentPosition);&#xA;&#x9;&#x9;matcher = pattern.matcher(sqlStatement);&#xA;&#x9;&#x9;}&#xA;&#x9;&#x9;// Parse Statement&#xA;&#x9;&#x9;Statement statement = CCJSqlParserUtil.parse(sqlStatement);&#xA;&#x9;&#x9;if (statement.getClass().toString().equals(&quot;class net.sf.jsqlparser.statement.select.Select&quot;)){&#xA;&#x9;&#x9;&#x9;// Ermittle Spalten und schreibe diese in Liste&#xA;&#x9;&#x9;&#x9;Select selectStatement = (Select) statement;&#xA;&#x9;&#x9;&#x9;List&lt;String> columnList = new ArrayList&lt;String>();&#xA;&#x9;&#x9;&#x9;List&lt;SelectItem> selectItems = null;&#xA;&#x9;&#x9;&#x9;if (selectStatement.getSelectBody() instanceof SetOperationList){&#xA;&#x9;&#x9;&#x9;&#x9;List&lt;SelectBody> selectBodies= ((SetOperationList) selectStatement.getSelectBody()).getSelects();&#xA;&#x9;&#x9;&#x9;&#x9;for (int i = 0; i &lt; selectBodies.size(); i++){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;PlainSelect plainSelect = (PlainSelect) selectBodies.get(i);&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;selectItems = plainSelect.getSelectItems();&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;selectItems.stream().forEach(selectItem -> {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if (!columnList.contains(selectItem.toString())) columnList.add(selectItem.toString());&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;});&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;&#x9;PlainSelect plainSelect = (PlainSelect) selectStatement.getSelectBody();&#xA;&#x9;&#x9;&#x9;&#x9;selectItems = plainSelect.getSelectItems();&#xA;&#x9;&#x9;&#x9;&#x9;selectItems.stream().forEach(selectItem -> columnList.add(selectItem.toString()));&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Spalten = columnList.toString();&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Spalten = null;&#xA;&#x9;&#x9;}&#xA;&#x9;} catch (JSQLParserException e) {&#xA;&#x9;&#x9;// Schreibe Fehler in Konsole und in das entsprechende Feld&#xA;&#x9;&#x9;StringWriter sw = new StringWriter();&#xA;&#x9;&#x9;PrintWriter pw = new PrintWriter(sw);&#xA;&#x9;&#x9;e.printStackTrace(pw);&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Spalten = &quot;Parsing-Fehler: Ungültige Syntax oder nicht gehandhabter Spezialfall&quot;;&#xA;&#x9;}&#xA;}&#xA;else{&#xA;&#x9;if (sqlStatement!=null &amp;&amp; sqlStatement.contains(&quot;MERGE&quot;)){&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Spalten = &quot;MERGE-Statements nicht für Parsing unterstützt&quot;;&#xA;&#x9;}&#xA;&#x9;if (sqlStatement!=null &amp;&amp; sqlStatement.contains(&quot;EXECUTE&quot;)){&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Spalten = &quot;EXECUTE-Statements nicht für Parsing unterstützt&quot;;&#xA;&#x9;}&#xA;}&#xA;XML_Input_ergaenzt_2.Projektname=XML_Input_ergaenzt_4.Projektname;&#xA;XML_Input_ergaenzt_2.Subpfad=XML_Input_ergaenzt_4.Subpfad;&#xA;XML_Input_ergaenzt_2.Jobname=XML_Input_ergaenzt_4.Jobname;&#xA;XML_Input_ergaenzt_2.Version=XML_Input_ergaenzt_4.Version;&#xA;XML_Input_ergaenzt_2.Jobname_Technisch=XML_Input_ergaenzt_4.Jobname_Technisch;&#xA;XML_Input_ergaenzt_2.Komponente=XML_Input_ergaenzt_4.Komponente;"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="import net.sf.jsqlparser.JSQLParserException;&#xA;import net.sf.jsqlparser.parser.CCJSqlParserUtil;&#xA;import net.sf.jsqlparser.statement.Statement;&#xA;import net.sf.jsqlparser.statement.select.*;&#xA;import java.util.ArrayList;&#xA;import java.util.List;&#xA;import java.io.StringWriter;&#xA;import java.io.PrintWriter;&#xA;import java.util.regex.Pattern;&#xA;import java.util.regex.Matcher;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
