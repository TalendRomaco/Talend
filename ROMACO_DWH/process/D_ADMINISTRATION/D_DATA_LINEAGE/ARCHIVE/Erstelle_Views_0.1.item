    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;CREATE VIEW [dbo].[DL_V_&quot;+context.Präfix+&quot;_Flow_Quelle_Ziel]&#xD;&#xA;AS&#xD;&#xA;  (SELECT i. [Projektname],&#xD;&#xA;          i. [Jobname_Technisch],&#xD;&#xA;          i. Quelle,&#xD;&#xA;          i. Quelle_Tabelle,&#xD;&#xA;          i. Quelle_Datei,&#xD;&#xA;          i. Datenbank AS Quelle_Datenbank,&#xD;&#xA;          i. \&quot;Schema\&quot;  AS Quelle_Schema,&#xD;&#xA;          o. Ziel,&#xD;&#xA;          o.Ziel_Tabelle,&#xD;&#xA;          o. Ziel_Datei,&#xD;&#xA;          o. Datenbank AS Ziel_Datenbank,&#xD;&#xA;          o. \&quot;Schema\&quot;  AS Ziel_Schema,&#xD;&#xA;          CASE&#xD;&#xA;            WHEN i.Quelle_Eindeutig = 1&#xD;&#xA;                  OR o.Ziel_Eindeutig = 1 THEN 'TRUE'&#xD;&#xA;            ELSE 'FALSE'&#xD;&#xA;          END          AS Flow_Eindeutig,&#xD;&#xA;          j.Neueste_Version&#xD;&#xA;   FROM   [dbo].[DL_V_&quot;+context.Präfix+&quot;_Input_Gesamt] i&#xD;&#xA;          INNER JOIN dbo.DL_V_&quot;+context.Präfix+&quot;_Output_Gesamt o&#xD;&#xA;                  ON ( i.Projektname = o.Projektname&#xD;&#xA;                       AND i.Jobname_Technisch = o.Jobname_Technisch )&#xD;&#xA;          LEFT JOIN dbo.DL_V_&quot;+context.Präfix+&quot;_Jobs j&#xD;&#xA;                 ON i.Jobname_Technisch = j.Jobname_Technisch) &quot;"/>
