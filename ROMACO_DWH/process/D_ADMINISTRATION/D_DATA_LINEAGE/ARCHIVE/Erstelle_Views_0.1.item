  <node componentName="tMSSqlRow" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="96" posY="-64">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBRow_2" show="false"/>
