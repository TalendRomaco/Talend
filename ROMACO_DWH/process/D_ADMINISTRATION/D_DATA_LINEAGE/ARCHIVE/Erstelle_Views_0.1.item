    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;CREATE VIEW [dbo].[DL_V_&quot;+context.Präfix+&quot;_File_Flow]&#xD;&#xA;AS&#xD;&#xA;  (SELECT [Jobname_Technisch] AS Quelle,&#xD;&#xA;          Pfad                AS Ziel,&#xD;&#xA;          NULL                AS Quelle_Datei,&#xD;&#xA;          Pfad                AS Ziel_Datei,&#xD;&#xA;          Jobname_Technisch,&#xD;&#xA;          Jobname_Technisch   AS Quelle_Alternativ,&#xD;&#xA;          Pfad                AS Ziel_Alternativ&#xD;&#xA;   FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_FileOutput]&#xD;&#xA;   UNION&#xD;&#xA;   SELECT Pfad                                    AS Quelle,&#xD;&#xA;          i.Jobname_Technisch + ': ' + Komponente AS Ziel,&#xD;&#xA;          Pfad                                    AS Quelle_Datei,&#xD;&#xA;          NULL                                    AS Ziel_Datei,&#xD;&#xA;          i.Jobname_Technisch,&#xD;&#xA;          Pfad                                    AS Quelle_Alternativ,&#xD;&#xA;          Cast(j.Jobname_ID AS VARCHAR(max)) + ' - '&#xD;&#xA;          + Komponente                            AS Ziel_Alternativ&#xD;&#xA;   FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_FileInput] i&#xD;&#xA;          LEFT JOIN DL_&quot;+context.Präfix+&quot;_Jobs j&#xD;&#xA;                 ON i.[Jobname_Technisch] = j.Jobname_Technisch&#xD;&#xA;   WHERE  Dateiname NOT LIKE 'Leerer Kontext:%'&#xD;&#xA;   UNION&#xD;&#xA;   SELECT i.Jobname_Technisch + ': ' + Komponente AS Quelle,&#xD;&#xA;          i.Jobname_Technisch                     AS Ziel,&#xD;&#xA;          Pfad                                    AS Quelle_Datei,&#xD;&#xA;          NULL                                    AS Ziel_Datei,&#xD;&#xA;          i.Jobname_Technisch,&#xD;&#xA;          Cast(j.Jobname_ID AS VARCHAR(max)) + ' - '&#xD;&#xA;          + Komponente                            AS Quelle__Alternativ,&#xD;&#xA;          i.Jobname_Technisch                     AS Ziel_Alternativ&#xD;&#xA;   FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_FileInput] i&#xD;&#xA;          LEFT JOIN DL_&quot;+context.Präfix+&quot;_Jobs j&#xD;&#xA;                 ON i.[Jobname_Technisch] = j.Jobname_Technisch&#xD;&#xA;   WHERE  Dateiname NOT LIKE 'Leerer Kontext:%') &quot;"/>
