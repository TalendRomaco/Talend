    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;CREATE VIEW [dbo].[DL_V_&quot;+context.Präfix+&quot;_Output_Gesamt]&#xD;&#xA;AS&#xD;&#xA;  (SELECT t1.Projektname,&#xD;&#xA;          t1.Jobname_Technisch,&#xD;&#xA;          t1.Ziel,&#xD;&#xA;          t1.Ziel_Tabelle,&#xD;&#xA;          t1.Ziel_Datei,&#xD;&#xA;          t1.Datenbank,&#xD;&#xA;          t1.\&quot;Schema\&quot;,&#xD;&#xA;          t2.Ziel_Eindeutig&#xD;&#xA;   FROM   (SELECT t. [Projektname],&#xD;&#xA;                  t. [Jobname_Technisch],&#xD;&#xA;                  t. [Zieltabelle_Aufgeloest] AS Ziel,&#xD;&#xA;                  t. [Zieltabelle_Aufgeloest] AS Ziel_Tabelle,&#xD;&#xA;                  NULL                        AS Ziel_Datei,&#xD;&#xA;                  t.[Datenbank_Aufgeloest]    AS Datenbank,&#xD;&#xA;                  t.[Schema_Aufgeloest]       AS \&quot;Schema\&quot;&#xD;&#xA;           FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_DBOutput] t&#xD;&#xA;           UNION&#xD;&#xA;           SELECT f. [Projektname],&#xD;&#xA;                  f. [Jobname_Technisch],&#xD;&#xA;                  f.Pfad AS Ziel,&#xD;&#xA;                  NULL   AS Ziel_Tabelle,&#xD;&#xA;                  f.Pfad AS Ziel_Datei,&#xD;&#xA;                  NULL   AS Datenbank,&#xD;&#xA;                  NULL   AS \&quot;Schema\&quot;&#xD;&#xA;           FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_FileOutput] f) t1&#xD;&#xA;          LEFT JOIN (SELECT Projektname,&#xD;&#xA;                            Jobname_Technisch,&#xD;&#xA;                            CASE&#xD;&#xA;                              WHEN Count (DISTINCT Ziel) > 1 THEN 0&#xD;&#xA;                              ELSE 1&#xD;&#xA;                            END AS Ziel_Eindeutig&#xD;&#xA;                     FROM   (SELECT t. [Projektname],&#xD;&#xA;                                    t. [Jobname_Technisch],&#xD;&#xA;                                    t. [Zieltabelle_Aufgeloest] AS Ziel&#xD;&#xA;                             FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_DBOutput] t&#xD;&#xA;                             UNION&#xD;&#xA;                             SELECT f. [Projektname],&#xD;&#xA;                                    f. [Jobname_Technisch],&#xD;&#xA;                                    f.Pfad AS Ziel&#xD;&#xA;                             FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_FileOutput] f) t1&#xD;&#xA;                     GROUP  BY Projektname,&#xD;&#xA;                               Jobname_Technisch) t2&#xD;&#xA;                 ON t1.Projektname = t2.Projektname&#xD;&#xA;                    AND t1.Jobname_Technisch = t2.Jobname_Technisch) &quot;"/>
