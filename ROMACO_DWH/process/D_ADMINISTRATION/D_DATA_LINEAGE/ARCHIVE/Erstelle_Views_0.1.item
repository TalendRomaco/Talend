    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;CREATE VIEW [dbo].[DL_V_&quot;+context.Präfix+&quot;_Flow]&#xD;&#xA;AS&#xD;&#xA;  (SELECT f.Quelle,&#xD;&#xA;          f. Ziel,&#xD;&#xA;          f.Jobname_Technisch,&#xD;&#xA;          f.Datenbank,&#xD;&#xA;          f.\&quot;Schema\&quot;,&#xD;&#xA;          f.Quelle_Tabelle,&#xD;&#xA;          f.Ziel_Tabelle,&#xD;&#xA;          f.Quelle_Datei,&#xD;&#xA;          f.Ziel_Datei,&#xD;&#xA;          j.Neueste_Version,&#xD;&#xA;          f.Quelle_Alternativ,&#xD;&#xA;          f.Ziel_Alternativ&#xD;&#xA;   FROM   (SELECT [Quelle],&#xD;&#xA;                  [Ziel],&#xD;&#xA;                  [Jobname_Technisch],&#xD;&#xA;                  [Datenbank],&#xD;&#xA;                  [Schema],&#xD;&#xA;                  Quelle_Tabelle,&#xD;&#xA;                  Ziel_Tabelle,&#xD;&#xA;                  CASE&#xD;&#xA;                    WHEN Quelle_Tabelle IS NULL THEN NULL&#xD;&#xA;                    ELSE 'N/A'&#xD;&#xA;                  END AS Quelle_Datei,&#xD;&#xA;                  CASE&#xD;&#xA;                    WHEN Ziel_Tabelle IS NULL THEN NULL&#xD;&#xA;                    ELSE 'N/A'&#xD;&#xA;                  END AS Ziel_Datei,&#xD;&#xA;                  Quelle_Alternativ,&#xD;&#xA;                  Ziel_Alternativ&#xD;&#xA;           FROM   [dbo].[DL_V_&quot;+context.Präfix+&quot;_DB_Flow]&#xD;&#xA;           UNION&#xD;&#xA;           SELECT [Quelle],&#xD;&#xA;                  [Ziel],&#xD;&#xA;                  [Jobname_Technisch],&#xD;&#xA;                  NULL AS Datenbank,&#xD;&#xA;                  NULL AS \&quot;Schema\&quot;,&#xD;&#xA;                  CASE&#xD;&#xA;                    WHEN Quelle_Datei IS NULL THEN NULL&#xD;&#xA;                    ELSE 'N/A'&#xD;&#xA;                  END  AS Quelle_Tabelle,&#xD;&#xA;                  CASE&#xD;&#xA;                    WHEN Ziel_Datei IS NULL THEN NULL&#xD;&#xA;                    ELSE 'N/A'&#xD;&#xA;                  END  AS Ziel_Tabelle,&#xD;&#xA;                  Quelle_Datei,&#xD;&#xA;                  Ziel_Datei,&#xD;&#xA;                  Quelle_Alternativ,&#xD;&#xA;                  Ziel_Alternativ&#xD;&#xA;           FROM   [dbo].[DL_V_&quot;+context.Präfix+&quot;_File_Flow]) f&#xD;&#xA;          LEFT JOIN dbo.DL_V_&quot;+context.Präfix+&quot;_Jobs j&#xD;&#xA;                 ON f.Jobname_Technisch = j.Jobname_Technisch) &quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="DIE_ON_ERROR" value="true"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;&quot;" show="false"/>
