    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;CREATE VIEW [dbo].[DL_V_&quot;+context.Präfix+&quot;_Input_Gesamt]&#xD;&#xA;AS&#xD;&#xA;  (SELECT t1.Projektname,&#xD;&#xA;          t1.Jobname_Technisch,&#xD;&#xA;          t1.Quelle,&#xD;&#xA;          t1.Quelle_Tabelle,&#xD;&#xA;          t1.Quelle_Datei,&#xD;&#xA;          t1.Datenbank,&#xD;&#xA;          t1.\&quot;Schema\&quot;,&#xD;&#xA;          t2.Quelle_Eindeutig&#xD;&#xA;   FROM   (SELECT t. [Projektname],&#xD;&#xA;                  t. [Jobname_Technisch],&#xD;&#xA;                  t. [Quelltabelle_Aufgeloest] AS Quelle,&#xD;&#xA;                  t. [Quelltabelle_Aufgeloest] AS Quelle_Tabelle,&#xD;&#xA;                  NULL                         AS Quelle_Datei,&#xD;&#xA;                  t.Datenbank,&#xD;&#xA;                  t. \&quot;Schema\&quot;&#xD;&#xA;           FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_DBInput_Tabellen] t&#xD;&#xA;           UNION&#xD;&#xA;           SELECT f. [Projektname],&#xD;&#xA;                  f. [Jobname_Technisch],&#xD;&#xA;                  f.Pfad AS Quelle,&#xD;&#xA;                  NULL   AS Quelle_Tabelle,&#xD;&#xA;                  f.Pfad AS Quelle_Datei,&#xD;&#xA;                  NULL   AS Datenbank,&#xD;&#xA;                  NULL   AS \&quot;Schema\&quot;&#xD;&#xA;           FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_FileInput] f) t1&#xD;&#xA;          LEFT JOIN (SELECT Projektname,&#xD;&#xA;                            Jobname_Technisch,&#xD;&#xA;                            CASE&#xD;&#xA;                              WHEN Count (DISTINCT Quelle) > 1 THEN 0&#xD;&#xA;                              ELSE 1&#xD;&#xA;                            END AS Quelle_Eindeutig&#xD;&#xA;                     FROM   (SELECT t. [Projektname],&#xD;&#xA;                                    t. [Jobname_Technisch],&#xD;&#xA;                                    t. [Quelltabelle_Aufgeloest] AS Quelle&#xD;&#xA;                             FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_DBInput_Tabellen] t&#xD;&#xA;                             UNION&#xD;&#xA;                             SELECT f. [Projektname],&#xD;&#xA;                                    f. [Jobname_Technisch],&#xD;&#xA;                                    f.Pfad AS Quelle&#xD;&#xA;                             FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_FileInput] f) t1&#xD;&#xA;                     GROUP  BY Projektname,&#xD;&#xA;                               Jobname_Technisch) t2&#xD;&#xA;                 ON t1.Projektname = t2.Projektname&#xD;&#xA;                    AND t1.Jobname_Technisch = t2.Jobname_Technisch&#xD;&#xA;   WHERE  Quelle IS NOT NULL&#xD;&#xA;          AND Quelle NOT LIKE '') &quot;"/>
