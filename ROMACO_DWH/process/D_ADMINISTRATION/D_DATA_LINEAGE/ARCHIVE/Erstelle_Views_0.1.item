    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;CREATE VIEW [dbo].[DL_V_&quot;+context.Präfix+&quot;_Jobs]&#xD;&#xA;AS&#xD;&#xA;  (SELECT t.[Projektname],&#xD;&#xA;          t.Subpfad,&#xD;&#xA;          t.[Jobname],&#xD;&#xA;          t.[Version],&#xD;&#xA;          t.[Jobname_Technisch],&#xD;&#xA;          t.Neueste_Version&#xD;&#xA;   FROM   (SELECT t1.[Projektname],&#xD;&#xA;                  t1.Subpfad,&#xD;&#xA;                  t1.[Jobname],&#xD;&#xA;                  t1.[Version],&#xD;&#xA;                  t1.[Jobname_Technisch],&#xD;&#xA;                  CASE&#xD;&#xA;                    WHEN t1.Version = t2.Max_Version THEN 'TRUE'&#xD;&#xA;                    ELSE 'FALSE'&#xD;&#xA;                  END                             AS Neueste_Version,&#xD;&#xA;                  Row_number()&#xD;&#xA;                    OVER (&#xD;&#xA;                      partition BY t1.Projektname, Jobname_Technisch&#xD;&#xA;                      ORDER BY Jobname_Technisch) AS num&#xD;&#xA;           FROM   [dbo].[DL_&quot;+context.Präfix+&quot;_Jobs] t1&#xD;&#xA;                  LEFT JOIN (SELECT Projektname,&#xD;&#xA;                                    Jobname,&#xD;&#xA;                                    Max(Version) AS Max_Version&#xD;&#xA;                             FROM   dbo.DL_&quot;+context.Präfix+&quot;_Jobs&#xD;&#xA;                             GROUP  BY Projektname,&#xD;&#xA;                                       Jobname) t2&#xD;&#xA;                         ON t1.Projektname = t2.Projektname&#xD;&#xA;                            AND t1.Jobname = t2.Jobname) t&#xD;&#xA;   WHERE  num = 1) &quot;"/>
