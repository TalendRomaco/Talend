    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&#xD;&#xA;&quot;CREATE VIEW [&quot;+context.schema+&quot;].[v_&quot;+context.praefix+&quot;db_flow]&#xD;&#xA;AS&#xD;&#xA;  (SELECT [JOBNAME_TECHNICAL]      AS [SOURCE],&#xD;&#xA;          [TARGET_TABLE_RESOLVED] AS [TARGET],&#xD;&#xA;          NULL                     AS [SOURCE_TABLE],&#xD;&#xA;          TARGET_TABLE_RESOLVED   AS [TARGET_TABLE],&#xD;&#xA;          JOBNAME_TECHNICAL,&#xD;&#xA;          DATABASE_RESOLVED     AS [DATABASE],&#xD;&#xA;          SCHEMA_RESOLVED        AS \&quot;SCHEMA\&quot;,&#xD;&#xA;          [JOBNAME_TECHNICAL]      AS [SOURCE_ALTERNATIVE],&#xD;&#xA;          TARGET_TABLE_RESOLVED   AS [TARGET_ALTERNATIVE]&#xD;&#xA;   FROM   [&quot;+context.schema+&quot;].[&quot;+context.praefix+&quot;db_output]&#xD;&#xA;   WHERE  [TARGET_TABLE_RESOLVED] NOT LIKE 'Leerer Kontext:%'&#xD;&#xA;          AND TARGET_TABLE_RESOLVED NOT LIKE&#xD;&#xA;              'Kontextvariable nicht vorhanden:%'&#xD;&#xA;   UNION&#xD;&#xA;   SELECT [SOURCE_TABLE_RESOLVED]                 AS [SOURCE],&#xD;&#xA;          i.[JOBNAME_TECHNICAL] + ': ' + COMPONENT AS [TARGET],&#xD;&#xA;          [SOURCE_TABLE_RESOLVED]                 AS [SOURCE_TABLE],&#xD;&#xA;          NULL                                      AS [TARGET_TABLE],&#xD;&#xA;          i.JOBNAME_TECHNICAL,&#xD;&#xA;          [DATABASE],&#xD;&#xA;          [SCHEMA],&#xD;&#xA;          [SOURCE_TABLE_RESOLVED]                 AS [SOURCE_ALTERNATIVE],&#xD;&#xA;          Cast(j.Jobname_ID AS VARCHAR(max)) + ' - '&#xD;&#xA;          + COMPONENT                              AS [TARGET_ALTERNATIVE]&#xD;&#xA;   FROM   [&quot;+context.schema+&quot;].[&quot;+context.praefix+&quot;db_input_table] i&#xD;&#xA;          LEFT JOIN &quot;+context.praefix+&quot;jobs j&#xD;&#xA;                 ON i.[JOBNAME_TECHNICAL] = j.JOBNAME_TECHNICAL&#xD;&#xA;   WHERE  SOURCE_TABLE_RESOLVED IS NOT NULL&#xD;&#xA;          AND SOURCE_TABLE_RESOLVED NOT LIKE ''&#xD;&#xA;   UNION&#xD;&#xA;   SELECT i.[JOBNAME_TECHNICAL] + ': ' + COMPONENT AS [SOURCE],&#xD;&#xA;          i.[JOBNAME_TECHNICAL]                     AS [TARGET],&#xD;&#xA;          SOURCE_TABLE_RESOLVED                   AS [SOURCE_TABLE],&#xD;&#xA;          NULL                                      AS [TARGET_TABLE],&#xD;&#xA;          i.JOBNAME_TECHNICAL,&#xD;&#xA;          [DATABASE],&#xD;&#xA;          [SCHEMA],&#xD;&#xA;          Cast(j.Jobname_ID AS VARCHAR(max)) + ' - '&#xD;&#xA;          + COMPONENT                              AS [SOURCE_ALTERNATIVE],&#xD;&#xA;          i.JOBNAME_TECHNICAL                       AS [TARGET_ALTERNATIVE]&#xD;&#xA;   FROM   [&quot;+context.schema+&quot;].[&quot;+context.praefix+&quot;db_input_table] i&#xD;&#xA;          LEFT JOIN &quot;+context.praefix+&quot;jobs j&#xD;&#xA;                 ON i.[JOBNAME_TECHNICAL] = j.JOBNAME_TECHNICAL&#xD;&#xA;   WHERE  SOURCE_TABLE_RESOLVED IS NOT NULL&#xD;&#xA;          AND SOURCE_TABLE_RESOLVED NOT LIKE '') &quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
