    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;CREATE VIEW &quot;+ context.schema+&quot;.[v_&quot;+context.praefix+&quot;db_input]&#xD;&#xA;AS&#xD;&#xA;  (SELECT i.[PROJECT_NAME],&#xD;&#xA;          i.[SUBPATH],&#xD;&#xA;          i.[JOBNAME],&#xD;&#xA;          i.[VERSION],&#xD;&#xA;          i.[JOBNAME_TECHNICAL],&#xD;&#xA;          j.NEWEST_VERSION,&#xD;&#xA;          [COMPONENT],&#xD;&#xA;          [STATEMENT],&#xD;&#xA;          [STATEMENT_RESOLVED]&#xD;&#xA;&#x9;&#x9;  ,[HOST_TALEND]&#xD;&#xA;&#x9;&#x9;  ,[HOST_CONTEXT]&#xD;&#xA;&#x9;&#x9;  ,[HOST_CONNECTION]&#xD;&#xA;&#x9;&#x9;  ,[HOST_RESOLVED]&#xD;&#xA;&#x9;&#x9;  ,[DATABASE_TALEND]&#xD;&#xA;&#x9;&#x9;  ,[DATABASE_CONTEXT]&#xD;&#xA;&#x9;&#x9;  ,[DATABASE_CONNECTION]&#xD;&#xA;&#x9;&#x9;  ,[DATABASE_RESOLVED]&#xD;&#xA;&#x9;&#x9;  ,[SCHEMA_TALEND]&#xD;&#xA;&#x9;&#x9;  ,[SCHEMA_CONTEXT]&#xD;&#xA;&#x9;&#x9;  ,[SCHEMA_CONNECTION]&#xD;&#xA;&#x9;&#x9;  ,[SCHEMA_RESOLVED]&#xD;&#xA;   FROM &quot;+ context.schema+&quot;.&quot;+context.praefix+&quot;db_input i&#xD;&#xA;          LEFT JOIN &quot;+ context.schema+&quot;.v_&quot;+context.praefix+&quot;jobs j&#xD;&#xA;                 ON i.JOBNAME_TECHNICAL = j.JOBNAME_TECHNICAL) &quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="DIE_ON_ERROR" value="true"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="ACTIVE_DIR_AUTH" value="false" show="false"/>
    <elementParameter field="CHECK" name="PROPAGATE_RECORD_SET" value="false"/>
    <elementParameter field="COLUMN_LIST" name="RECORD_SET_COLUMN" value="" show="false"/>
