  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="480" posY="992">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_4" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="String statement_Aufgeloest = (String) globalMap.get(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente);&#xA;if(statement_Aufgeloest != null &amp;&amp; Komponente_mit_Kontexten.Kontext_Name != null) {&#xA;&#x9;// Prüfe, ob Kontextvariable leer oder null ist und ob diese im Statement verwendet wird&#xA;&#x9;if ((Komponente_mit_Kontexten.Kontext_Wert == null || Komponente_mit_Kontexten.Kontext_Wert.equals(&quot;&quot;)) &amp;&amp;  (statement_Aufgeloest.matches(&quot;[\\s\\S]*\&quot;[ +]*(\\([^()]*\\) *)?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ +][^\&quot;]*\&quot;&quot;) || statement_Aufgeloest.matches(&quot;[\\s\\S]*\&quot;[ +]*(\\([^()]*\\) *)?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ ]*$&quot;) || statement_Aufgeloest.matches(Komponente_mit_Kontexten.Kontext_Name))){&#xA;&#x9;&#x9;globalMap.put(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente, &quot;Leerer Kontext: &quot;+Komponente_mit_Kontexten.Kontext_Name);&#xA;&#x9;}&#xA;&#x9;else{&#xA;&#x9;&#x9;// Ersetze Kontextvariable inklusive die umgebenden, für Java-Syntax benötigten Zeichen, wenn diese am Anfang oder zwischen zwei Teilen des Statements verwendet wird&#xA;&#x9;&#x9;statement_Aufgeloest = statement_Aufgeloest.replaceAll(&quot;\&quot;[ +]*(\\([^()]*\\) *)?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ +][^\&quot;]*\&quot;&quot;, Komponente_mit_Kontexten.Kontext_Wert);&#xA;&#x9;&#x9;// Ersetze Kontextvariable inklusive die umgebenden, für Java-Syntax benötigten Zeichen, wenn diese am Ende des Statements verwendet wird&#xA;&#x9;&#x9;statement_Aufgeloest = statement_Aufgeloest.replaceAll(&quot;\&quot;[ +]*(\\([^()]*\\) *)?&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;[ ]*$&quot;, Komponente_mit_Kontexten.Kontext_Wert);&#xA;&#x9;&#x9;// Ersetze Kontextvariable, wenn diese das gesamte Statement ist&#xA;&#x9;&#x9;statement_Aufgeloest = statement_Aufgeloest.replaceAll(&quot;^&quot;+Komponente_mit_Kontexten.Kontext_Name+&quot;$&quot;, Komponente_mit_Kontexten.Kontext_Wert);&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;globalMap.put(Komponente_mit_Kontexten.Projektname + Komponente_mit_Kontexten.Jobname_Technisch + Komponente_mit_Kontexten.Komponente, statement_Aufgeloest);&#xA;&#x9;}&#xA;}&#xA;"/>
