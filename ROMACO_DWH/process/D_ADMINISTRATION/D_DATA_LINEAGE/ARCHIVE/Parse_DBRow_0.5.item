    <elementParameter field="MEMO_JAVA" name="CODE" value="String sqlStatement = Finale_Daten_ergaenzt.Statement_Aufgeloest;&#xA;if (sqlStatement==null || sqlStatement.equals(&quot;&quot;) || sqlStatement.contains(&quot;Leerer Kontext:&quot;)){&#xA;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = null;&#xA;} else{&#xA;if (sqlStatement.contains(&quot;MERGE&quot;)){&#xA;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;MERGE&quot;;&#xA;}else{&#xA;if (sqlStatement.contains(&quot;EXECUTE&quot;)){&#xA;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;EXECUTE&quot;;&#xA;}else{&#xA;if(sqlStatement.contains(&quot;globalMap&quot;)){&#xA;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;Statement kann wegen globalMap nicht geparst werden&quot;;&#xA;}&#xA;else{&#xA;&#x9;try{&#xA;&#x9;&#x9;// Identifiziere erstes Statement und begrenze den String auf dieses&#xA;&#x9;&#x9;Pattern pattern = Pattern.compile(&quot;(?:DELETE|SELECT|INSERT(?! INTO)|UPDATE|TRUNCATE|DROP|CREATE|MERGE|EXECUTE)&quot;);&#xA;&#x9;&#x9;Matcher matcher = pattern.matcher(sqlStatement);&#xA;&#x9;&#x9;boolean firstStatementFound = false;&#xA;&#x9;&#x9;while(matcher.find()){&#xA;&#x9;&#x9;&#x9;int currentPosition = matcher.start();&#xA;&#x9;&#x9;&#x9;String currentSubstring = sqlStatement.substring(0, currentPosition);&#xA;&#x9;&#x9;&#x9;long countOpeningBracket = currentSubstring.chars().filter(ch -> ch == '(').count();&#xA;&#x9;&#x9;&#x9;long countClosingBracket = currentSubstring.chars().filter(ch -> ch == ')').count();&#xA;&#x9;&#x9;&#x9;if(countOpeningBracket == countClosingBracket){&#xA;&#x9;&#x9;&#x9;&#x9;if (firstStatementFound){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;sqlStatement = sqlStatement.substring(0, currentPosition);&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;&#x9;firstStatementFound = true;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;}&#xA;&#x9;&#x9;// Parse Statement&#xA;&#x9;&#x9;Statement statement = CCJSqlParserUtil.parse(sqlStatement);&#xA;&#x9;&#x9;// Ermittle Statement-Typ&#xA;&#x9;&#x9;switch (statement.getClass().toString()){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.delete.Delete&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;DELETE&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.select.Select&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;SELECT&quot;; &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.insert.Insert&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;INSERT&quot;; &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.update.Update&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;UPDATE&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.truncate.Truncate&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;TRUNCATE&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.drop.Drop&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;DROP&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.create.table.CreateTable&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;CREATE&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;default:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = null;  &#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;} catch (JSQLParserException e) {&#xA;&#x9;&#x9;// Schreibe Fehler in Konsole und in das entsprechende Feld&#xA;&#x9;&#x9;StringWriter sw = new StringWriter();&#xA;&#x9;&#x9;PrintWriter pw = new PrintWriter(sw);&#xA;&#x9;&#x9;e.printStackTrace(pw);&#xA;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = &quot;Parsing-Fehler: Ungültige Syntax oder nicht gehandhabter Spezialfall&quot;;&#xA;&#x9;} catch (ClassCastException e) {&#xA;&#x9;&#x9;// Schreibe Fehler in Konsole und in das entsprechende Feld&#xA;&#x9;&#x9;StringWriter sw = new StringWriter();&#xA;&#x9;&#x9;PrintWriter pw = new PrintWriter(sw);&#xA;&#x9;&#x9;e.printStackTrace(pw);&#xA;&#x9;&#x9;Finale_Daten_ergaenzt_2.Statement_Typ = sw.toString();&#xA;&#x9;}&#xA;}&#xA;}&#xA;}&#xA;}&#xA;Finale_Daten_ergaenzt_2.Projektname=Finale_Daten_ergaenzt.Projektname;&#xA;Finale_Daten_ergaenzt_2.Subpfad=Finale_Daten_ergaenzt.Subpfad;&#xA;Finale_Daten_ergaenzt_2.Jobname=Finale_Daten_ergaenzt.Jobname;&#xA;Finale_Daten_ergaenzt_2.Version=Finale_Daten_ergaenzt.Version;&#xA;Finale_Daten_ergaenzt_2.Jobname_Technisch=Finale_Daten_ergaenzt.Jobname_Technisch;&#xA;Finale_Daten_ergaenzt_2.Komponente=Finale_Daten_ergaenzt.Komponente;&#xA;Finale_Daten_ergaenzt_2.Statement=Finale_Daten_ergaenzt.Statement;&#xA;Finale_Daten_ergaenzt_2.Statement_Aufgeloest=sqlStatement;&#xA;Finale_Daten_ergaenzt_2.Host_Talend=Finale_Daten_ergaenzt.Host_Talend;&#xA;Finale_Daten_ergaenzt_2.Host_Kontext=Finale_Daten_ergaenzt.Host_Kontext;&#xA;Finale_Daten_ergaenzt_2.Host_Verbindung=Finale_Daten_ergaenzt.Host_Verbindung;&#xA;Finale_Daten_ergaenzt_2.Host_Aufgeloest=Finale_Daten_ergaenzt.Host_Aufgeloest;&#xA;Finale_Daten_ergaenzt_2.Datenbank_Talend=Finale_Daten_ergaenzt.Datenbank_Talend;&#xA;Finale_Daten_ergaenzt_2.Datenbank_Kontext=Finale_Daten_ergaenzt.Datenbank_Kontext;&#xA;Finale_Daten_ergaenzt_2.Datenbank_Verbindung=Finale_Daten_ergaenzt.Datenbank_Verbindung;&#xA;Finale_Daten_ergaenzt_2.Datenbank_Aufgeloest=Finale_Daten_ergaenzt.Datenbank_Aufgeloest;&#xA;Finale_Daten_ergaenzt_2.Schema_Talend=Finale_Daten_ergaenzt.Schema_Talend;&#xA;Finale_Daten_ergaenzt_2.Schema_Kontext=Finale_Daten_ergaenzt.Schema_Kontext;&#xA;Finale