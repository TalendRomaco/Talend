    <elementParameter field="MEMO_JAVA" name="CODE" value="String sqlStatement = XML_Input_ergaenzt_4.Statement_bearbeitet;&#xA;if (sqlStatement==null || sqlStatement.equals(&quot;&quot;) || sqlStatement.contains(&quot;Leerer Kontext:&quot;)){&#xA;&#x9;XML_Input_ergaenzt_2.Statement_Typ = null;&#xA;&#x9;XML_Input_ergaenzt_2.Tabellen = null;&#xA;} else{&#xA;if (sqlStatement.contains(&quot;MERGE&quot;)){&#xA;&#x9;XML_Input_ergaenzt_2.Statement_Typ = &quot;MERGE&quot;;&#xA;&#x9;XML_Input_ergaenzt_2.Tabellen = null;&#xA;}else{&#xA;if (sqlStatement.contains(&quot;EXECUTE&quot;)){&#xA;&#x9;XML_Input_ergaenzt_2.Statement_Typ = &quot;EXECUTE&quot;;&#xA;&#x9;XML_Input_ergaenzt_2.Tabellen = null;&#xA;}else{&#xA;if(sqlStatement.contains(&quot;globalMap&quot;)){&#xA;&#x9;XML_Input_ergaenzt_2.Statement_Typ = &quot;Statement kann wegen globalMap nicht geparst werden&quot;;&#xA;&#x9;XML_Input_ergaenzt_2.Tabellen = null;&#xA;}&#xA;else{&#xA;&#x9;try{&#xA;&#x9;&#x9;// Parse Statement&#xA;&#x9;&#x9;Statement statement = CCJSqlParserUtil.parse(sqlStatement);&#xA;&#x9;&#x9;// Ermittle Statement-Typ&#xA;&#x9;&#x9;switch (statement.getClass().toString()){&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.delete.Delete&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Delete deleteStatement = (Delete) statement; &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Statement_Typ = &quot;DELETE&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = deleteStatement.getTable().toString();&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.select.Select&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Select selectStatement = (Select) statement;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Statement_Typ = &quot;SELECT&quot;; &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;TablesNamesFinder tablesNamesFinder = new TablesNamesFinder();&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = tablesNamesFinder.getTableList(selectStatement).toString();&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.insert.Insert&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Insert insertStatement = (Insert) statement;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Statement_Typ = &quot;INSERT&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = insertStatement.getTable().toString();&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.update.Update&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Update updateStatement = (Update) statement;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Statement_Typ = &quot;UPDATE&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = updateStatement.getTable().toString();&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;case &quot;class net.sf.jsqlparser.statement.truncate.Truncate&quot;:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;Truncate truncateStatement = (Truncate) statement;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Statement_Typ = &quot;TRUNCATE&quot;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = truncateStatement.getTable().toString();&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;break;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;default:&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Statement_Typ = null;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = null;&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;} catch (JSQLParserException e) {&#xA;&#x9;&#x9;// Schreibe Fehler in Konsole und in das entsprechende Feld&#xA;&#x9;&#x9;StringWriter sw = new StringWriter();&#xA;&#x9;&#x9;PrintWriter pw = new PrintWriter(sw);&#xA;&#x9;&#x9;e.printStackTrace(pw);&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Statement_Typ = sw.toString();&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = &quot;Parsing-Fehler: Ungültige Syntax oder nicht gehandhabter Spezialfall&quot;;&#xA;&#x9;} catch (ClassCastException e) {&#xA;&#x9;&#x9;// Schreibe Fehler in Konsole und in das entsprechende Feld&#xA;&#x9;&#x9;StringWriter sw = new StringWriter();&#xA;&#x9;&#x9;PrintWriter pw = new PrintWriter(sw);&#xA;&#x9;&#x9;e.printStackTrace(pw);&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Statement_Typ = sw.toString();&#xA;&#x9;&#x9;XML_Input_ergaenzt_2.Tabellen = sw.toString();&#xA;&#x9;}&#xA;}&#xA;}&#xA;}&#xA;}&#xA;XML_Input_ergaenzt_2.Projektname=XML_Input_ergaenzt_4.Projektname;&#xA;XML_Input_ergaenzt_2.Jobname_Technisch=XML_Input_ergaenzt_4.Jobname_Technisch;&#xA;XML_Input_ergaenzt_2.Komponente=XML_Input_ergaenzt_4.Komponente;"/>
