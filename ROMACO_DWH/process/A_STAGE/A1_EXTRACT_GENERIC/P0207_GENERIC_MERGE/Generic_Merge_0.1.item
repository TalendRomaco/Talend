    <elementParameter field="MEMO_JAVA" name="CODE" value="//Definiere PKs für Merge-Statement&#xA;//Sofern nur ein PK gegeben, setze Default PKs auf Wert von PK1&#xA;&#xA;context.PERSISTENT_TABLE_PK2 = &#xA;(context.PERSISTENT_TABLE_PK2 == null || context.PERSISTENT_TABLE_PK2.equals(&quot;&lt;TALEND_NULL>&quot;)? &#xA;context.PERSISTENT_TABLE_PK1 : context.PERSISTENT_TABLE_PK2);&#xA;&#xA;context.PERSISTENT_TABLE_PK3 = &#xA;(context.PERSISTENT_TABLE_PK3 == null || context.PERSISTENT_TABLE_PK3.equals(&quot;&lt;TALEND_NULL>&quot;)? &#xA;context.PERSISTENT_TABLE_PK1 : context.PERSISTENT_TABLE_PK3);&#xA;&#xA;context.TARGET_TABLE_PK2 = &#xA;(context.TARGET_TABLE_PK2 == null || context.TARGET_TABLE_PK2.equals(&quot;&lt;TALEND_NULL>&quot;)? &#xA;context.TARGET_TABLE_PK1 : context.TARGET_TABLE_PK2);&#xA;&#xA;context.TARGET_TABLE_PK3 = &#xA;(context.TARGET_TABLE_PK3 == null || context.TARGET_TABLE_PK3.equals(&quot;&lt;TALEND_NULL>&quot;) ? &#xA;context.TARGET_TABLE_PK1 : context.TARGET_TABLE_PK3);&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="Set PKs"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
