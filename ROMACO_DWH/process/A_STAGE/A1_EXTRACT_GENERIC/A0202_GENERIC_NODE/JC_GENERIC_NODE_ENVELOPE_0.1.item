  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="352" posY="-288">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="// Initiate&#xA;&#xA;// Check Context Variables on Errors&#xA;&#xA;&#x9;context.SOURCE_PARAM = routines.TtaRoutines.fixTalendNull(context.SOURCE_PARAM);&#xA;&#x9;context.DELTA_FIELD_NAME = routines.TtaRoutines.fixTalendNull(context.DELTA_FIELD_NAME);&#xA;&#x9;context.DELTA_LAST_KEY = routines.TtaRoutines.fixTalendNull(context.DELTA_LAST_KEY);&#xA;&#x9;context.TARGET_POST_SQL = routines.TtaRoutines.fixTalendNull(context.TARGET_POST_SQL);&#xA;&#x9;context.SOURCE_ADVANCED_PARAM = routines.TtaRoutines.fixTalendNull(context.SOURCE_ADVANCED_PARAM);&#xA;&#xA;// Define Target &amp; Switch Table&#xA;&#xA;String targetTable = context.TARGET_TABLE;&#xA;String switchTable = context.TARGET_TABLE + &quot;_SWT&quot;;&#xA;String deleteTable = context.TARGET_TABLE + &quot;_DEL&quot;;&#xA;String prepTable = context.TARGET_SWITCH ? switchTable : targetTable;&#xA;context.TARGET_TABLE = prepTable;&#xA;&#xA;globalMap.put(&quot;vTargetTable&quot;, targetTable);&#xA;globalMap.put(&quot;vSwitchTable&quot;, switchTable);&#xA;globalMap.put(&quot;vDeleteTable&quot;, deleteTable);&#xA;globalMap.put(&quot;vPrepTable&quot;, prepTable);&#x9;&#xA;&#xA;// Debugging&#xA;&#xA;if (context.DEBUG){&#xA;&#x9;System.out.println(&quot; '**********************&quot;);&#xA;&#x9;System.out.println(&quot; '** Node:   &quot; + context.STAGING_NODE);&#xA;&#x9;System.out.println(&quot; '** Type:   &quot; + context.SOURCE_TYPE);&#xA;&#x9;System.out.println(&quot; '** Source: &quot; + context.SOURCE_STRUCTURE);&#xA;&#x9;System.out.println(&quot; '** Delta:  &quot; + context.DELTA_METHOD);&#xA;&#x9;System.out.println(&quot; '** Where:  &quot; + context.SOURCE_PARAM);&#xA;&#x9;System.out.println(&quot; '** Offset: &quot; + context.DELTA_OFFSET);&#xA;&#x9;System.out.println(&quot; '** Query:  &quot; + (String)globalMap.get(&quot;query&quot;));&#xA;&#x9;System.out.println(&quot; '** Json:   &quot; + context.SOURCE_ADVANCED_PARAM);&#xA;&#x9;System.out.println(&quot; '** Switch: &quot; + context.TARGET_SWITCH);&#xA;&#x9;System.out.println(&quot; '** Recreate: &quot; + context.TARGET_RECREATE);&#xA;&#x9;System.out.println(&quot; '** Target: &quot; + prepTable);&#xA;&#x9;System.out.println(&quot; '** PostSQL: &quot; + context.TARGET_POST_SQL);&#xA;&#x9;System.out.println(&quot; '**********************&quot;);&#xA;&#x9;}&#xA;&#xA;&#xA;// Get Query Generator&#xA;&#xA;&#x9;TtaQueryGenerator queryGenerator = TtaQueryGenerator.getInstance();&#xA;&#xA;// Set Query Parameter&#xA;&#xA;&#x9;queryGenerator.setChore(context.CHORE_ID);&#xA;&#x9;queryGenerator.setSourceStructureType(context.SOURCE_TYPE);&#xA;&#x9;queryGenerator.setSourceStructureName(context.SOURCE_STRUCTURE);&#xA;&#x9;queryGenerator.setTargetTableName(prepTable);&#xA;&#x9;queryGenerator.setFields(context.SOURCE_FIELD);&#xA;&#x9;queryGenerator.setParam(context.SOURCE_PARAM);&#xA;&#x9;queryGenerator.setDeltaField(context.DELTA_FIELD_NAME);&#xA;&#x9;queryGenerator.setDeltaFieldType(context.DELTA_FIELD_TYPE);&#xA;&#x9;queryGenerator.setDeltaMethod(context.DELTA_METHOD);&#xA;&#x9;queryGenerator.setDeltaLastKey(context.DELTA_LAST_KEY);&#xA;&#x9;queryGenerator.setDeltaOffset(context.DELTA_OFFSET);&#xA;&#x9;queryGenerator.setDebug(context.DEBUG);&#xA;&#xA;// Generate Query to global Map&#xA;&#xA;&#x9;globalMap.put(&quot;query&quot;, queryGenerator.getQuery());&#xA;&#x9;&#xA;// Fix Quoting&#xA;&#xA;&#x9;context.SOURCE_ADVANCED_PARAM =  routines.TtaSerialization.fixQuotes(context.SOURCE_ADVANCED_PARAM);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="import java.util.Map;"/>
    <elementParameter field="TEXT" name="LABEL" value=" &lt;br>&lt;b>__UNIQUE_NAME__&lt;/b>&lt;br>__COMMENT__"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Set Execution Settings"/>
    <metadata connector="FLOW" name="tJava_1"/>
