    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot; &#xD;&#xA;select  &#xD;&#xA;cast(STR_PERSONALNR as int) as EMPLOYEE_ID, &#xD;&#xA;cast(dat_beginnzeit as Date) as DATE, &#xD;&#xA;sum(DEC_GESAMTZEIT)/100 as TOTAL_TIME, &#xD;&#xA;sum(DEC_GETEILTEZEIT)/100 as PERSONAL_TIME&#xD;&#xA;from&#xD;&#xA;(select&#xD;&#xA;distinct &#xD;&#xA;      [STR_AUFTRAGSNR]&#xD;&#xA;      ,[STR_AUFTRAGSBEZ]&#xD;&#xA;      ,[STR_AUFTRAGSREFBEZ]&#xD;&#xA;      ,[STR_BESCHREIBUNG1]&#xD;&#xA;      ,[STR_POSITIONSNR]&#xD;&#xA;      ,[STR_PERSONALNR]&#xD;&#xA;      ,[STR_STANDARDMASCH_NR]&#xD;&#xA;      ,[DAT_BUCHUNGSDAT]&#xD;&#xA;      ,[DAT_BEGINNZEIT]&#xD;&#xA;      ,[DAT_ENDZEIT]&#xD;&#xA;      ,[SRT_WERTTYP]&#xD;&#xA;      ,[DEC_GESAMTZEIT]&#xD;&#xA;      ,[DEC_GETEILTEZEIT]&#xD;&#xA;      ,[DEC_GEWICHTETEZEIT]&#xD;&#xA;      ,[DEC_GUTMENGE]&#xD;&#xA;      ,[DEC_AUSSCHUSS]&#xD;&#xA;      ,[DEC_NACHARBEIT]&#xD;&#xA;      ,[STR_BUCHUNGSNR]&#xD;&#xA;      ,[TIN_REVISION]&#xD;&#xA;from&#xD;&#xA;stg.s_zeusx_bde_ereignisse&#xD;&#xA;where SRT_WERTTYP = 16) as eindeutig&#xD;&#xA;group by cast(dat_beginnzeit as Date), STR_PERSONALNR&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
