    <elementParameter field="CHECK" name="TRIM_ALL_COLUMN" value="false"/>
    <elementParameter field="TABLE" name="TRIM_COLUMN">
      <elementValue elementRef="SCHEMA_COLUMN" value="WINDOWS_USER_NAME"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="USER_NAME"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="MODUL_NAME"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="OGR_NR"/>
