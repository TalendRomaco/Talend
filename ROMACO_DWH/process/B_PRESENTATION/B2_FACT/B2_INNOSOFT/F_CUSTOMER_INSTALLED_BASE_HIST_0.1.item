  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="96" posY="-64">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="Calendar cal = Calendar.getInstance();&#xA;&#xA;cal.add(Calendar.HOUR,-1);&#xA;&#xA;String month= (cal.get(Calendar.MONTH)+1) &lt; 10 ? &quot;0&quot; +  (cal.get(Calendar.MONTH)+1) : &quot;&quot; +  (cal.get(Calendar.MONTH)+1);&#xA;&#xA;int year = cal.get(Calendar.YEAR);&#xA;&#xA;int period = Integer.valueOf(year + &quot;&quot; +  month);&#xA;&#xA;globalMap.put(&quot;period&quot;, period);&#xA;&#xA;&#xA;System.out.println(&quot;Aktuelle Periode: &quot; + period);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="import java.util.Calendar;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Ermittel Zeitscheibe"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
