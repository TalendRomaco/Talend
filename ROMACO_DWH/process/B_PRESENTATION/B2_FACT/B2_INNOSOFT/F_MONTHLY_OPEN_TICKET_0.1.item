  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="96" posY="-256">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="Calendar calendar = Calendar.getInstance();&#xA;&#xA;calendar.set(Calendar.HOUR_OF_DAY, 0);&#xA;calendar.set(Calendar.MINUTE, 0);&#xA;calendar.set(Calendar.SECOND, 0);&#xA;calendar.set(Calendar.MILLISECOND, 0);&#xA;&#xA;int weekday = calendar.get(Calendar.DAY_OF_WEEK);&#xA;int days = Calendar.SUNDAY - weekday;&#xA;if (days &lt; 0)&#xA;{&#xA;    days += 7;&#xA;}&#xA;calendar.add(Calendar.DAY_OF_YEAR, days);&#xA;&#xA;globalMap.put(&quot;nextSunday&quot;, calendar.getTime());&#xA;&#xA;System.out.println(&#xA;  &quot;Nächster Sonntag lautet: &quot; + TalendDate.formatDate(&quot;dd.MM.yyyy&quot;, (Date)globalMap.get(&quot;nextSunday&quot;))&#xA;);&#xA;&#xA;&#xA;&#xA;"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="import java.util.Calendar;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Ermittel nächsten Sonntag"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
