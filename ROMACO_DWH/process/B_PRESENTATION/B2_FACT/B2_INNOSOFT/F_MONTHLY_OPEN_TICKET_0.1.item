    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT  problemnr, startzeit, endzeit, hotliner, maschnr, status,&#xD;&#xA;problemkey,&#xD;&#xA;vorgangstatus,&#xD;&#xA;&#xD;&#xA;ISNULL(&#xD;&#xA;CASE left(hotliner,3)&#xD;&#xA;           WHEN 'KA-' THEN  'Karlsruhe'&#xD;&#xA;           WHEN 'ST-' THEN 'Steinen'&#xD;&#xA;           WHEN 'BO-' THEN 'Bologna'&#xD;&#xA;           WHEN 'CO-' THEN 'Cologne'&#xD;&#xA;           ELSE NULL&#xD;&#xA;         END, 'no_group')  as HOTLINER_GROUP&#xD;&#xA;&#xD;&#xA;FROM   stg.s_innosoft_probleme&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;ORDER BY problemnr, endzeit, status&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
