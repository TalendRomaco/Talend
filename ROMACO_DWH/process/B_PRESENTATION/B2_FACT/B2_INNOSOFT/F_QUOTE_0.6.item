  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="120" posY="-240">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_2" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="Calendar cal = Calendar.getInstance();&#xA;&#xA;cal.add(Calendar.DATE,-1);&#xA;&#xA;String month= (cal.get(Calendar.MONTH)+1) &lt; 10 ? &quot;0&quot; +  (cal.get(Calendar.MONTH)+1) : &quot;&quot; +  (cal.get(Calendar.MONTH)+1);&#xA;&#xA;int year = cal.get(Calendar.YEAR);&#xA;&#xA;globalMap.put(&quot;period&quot;, year + &quot;&quot; +  month);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="import java.util.Calendar;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Setze Parameter"/>
    <metadata connector="FLOW" name="tJava_2"/>
  </node>
  <node componentName="tMSSqlInput" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="128" posY="448">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tMSSqlInput_1" show="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tMSSqlConnection_2"/>
    <elementParameter field="TEXT" name="HOST" value="&quot;&quot;" show="false"/>
    <elementParameter field="CLOSED_LIST" name="DRIVER" value="JTDS" show="false"/>
    <elementParameter field="TEXT" name="TYPE" value="MSSQL" show="false"/>
    <elementParameter field="TEXT" name="PORT" value="&quot;1433&quot;" show="false"/>
    <elementParameter field="TEXT" name="DB_SCHEMA" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="DBNAME" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="USER" value="&quot;&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:c11wYMQR8wDfX48TozKuZJyWcDi0c8aK526bd+Cc" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;s_innosoft_angkopfz&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT angkopfz.ANGNR,&#xD;&#xA;&#x9;&#x9;AINDEX,&#xD;&#xA;&#x9;&#x9;TITEL,&#xD;&#xA;&#x9;&#x9;case when tab.max_aindex is null then STATUS else 'ALT' end as STATUS,&#xD;&#xA;&#x9;&#x9;RABATT,&#xD;&#xA;&#x9;&#x9;isnull(SPRACHE,0) as SPRACHE,&#xD;&#xA;&#x9;&#x9;GUELTIG,&#xD;&#xA;&#x9;&#x9;ZAHLUNGSBEDINGUNG,&#xD;&#xA;&#x9;&#x9;DECKUNGSBEITRAG,&#xD;&#xA;&#x9;&#x9;ANSPRECHPARTNER,&#xD;&#xA;&#x9;&#x9;BEARBSTATUS,&#xD;&#xA;&#x9;&#x9;WIEDERVORLAGE,&#xD;&#xA;&#x9;&#x9;PNR,&#xD;&#xA;&#x9;&#x9;HLISTENR,&#xD;&#xA;&#x9;&#x9;ANSPRECHP2,&#xD;&#xA;&#x9;&#x9;AUFTRAGSWS,&#xD;&#xA;&#x9;&#x9;ADRNR3,&#xD;&#xA;&#x9;&#x9;ANSPRECHP3,&#xD;&#xA;&#x9;&#x9;AUART,&#xD;&#xA;&#x9;&#x9;MASCHNR,&#xD;&#xA;&#x9;&#x9;ZUSATZ1,&#xD;&#xA;&#x9;&#x9;ZUSATZ2,&#xD;&#xA;&#x9;&#x9;ZUSATZ3,&#xD;&#xA;&#x9;&#x9;ZUSATZ4,&#xD;&#xA;&#x9;&#x9;PREISART,&#xD;&#xA;&#x9;&#x9;ADRNR4,&#xD;&#xA;&#x9;&#x9;PRS,&#xD;&#xA;&#x9;&#x9;AUDISANFRAGE,&#xD;&#xA;&#x9;&#x9;AUDISANGEBOT,&#xD;&#xA;&#x9;&#x9;ANSPRECHP4,&#xD;&#xA;&#x9;&#x9;LIEFERBEDNR,&#xD;&#xA;&#x9;&#x9;LIEFERBEDDAUER,&#xD;&#xA;&#x9;&#x9;LIEFERBEDDAUERTYP,&#xD;&#xA;&#x9;&#x9;PROVISION,&#xD;&#xA;&#x9;&#x9;PREISDRUCK,&#xD;&#xA;&#x9;&#x9;ZW_EBENE,&#xD;&#xA;&#x9;&#x9;STORNO_ID,&#xD;&#xA;&#x9;&#x9;OBERGR,&#xD;&#xA;&#x9;&#x9;GESPERRT_AM,&#xD;&#xA;&#x9;&#x9;GESPERRT_VON,&#xD;&#xA;&#x9;&#x9;GESPERRT_TYP,&#xD;&#xA;&#x9;&#x9;STATUS_NOTEBOOK,&#xD;&#xA;&#x9;&#x9;GEAENDERT_AM,&#xD;&#xA;&#x9;&#x9;ABSCHLUSS_AM,&#xD;&#xA;&#x9;&#x9;PROBLEMNR,&#xD;&#xA;&#x9;&#x9;WV_BEGINN,&#xD;&#xA;&#x9;&#x9;WV_ENDE,&#xD;&#xA;&#x9;&#x9;WV_RECHN_PRO_JAHR,&#xD;&#xA;&#x9;&#x9;WV_RECHN_VON,&#xD;&#xA;&#x9;&#x9;WV_RECHN_BIS,&#xD;&#xA;&#x9;&#x9;WV_RECHN_NETTO,&#xD;&#xA;&#x9;&#x9;MEHRFACHDEBITOR,&#xD;&#xA;&#x9;&#x9;SPERRE_FAKTURA,&#xD;&#xA;&#x9;&#x9;SPERRE_FAKTURA_TXT,&#xD;&#xA;&#x9;&#x9;FAKTURASTATUS,&#xD;&#xA;&#x9;&#x9;BEARBEITER,&#xD;&#xA;&#x9;&#x9;VERSANDART,&#xD;&#xA;&#x9;&#x9;WV_NLISTE_ZEITRAUM,&#xD;&#xA;&#x9;&#x9;WV_BSTD_ABR,&#xD;&#xA;&#x9;&#x9;WV_JENDABR,&#xD;&#xA;&#x9;&#x9;VORLAGE,&#xD;&#xA;&#x9;&#x9;BESTELLER,&#xD;&#xA;&#x9;&#x9;BESTELLNR,&#xD;&#xA;&#x9;&#x9;BESTELLDATUM,&#xD;&#xA;&#x9;&#x9;APINTERN,&#xD;&#xA;&#x9;&#x9;VERTRIEBLER,&#xD;&#xA;&#x9;&#x9;LIEFERTERMIN,&#xD;&#xA;&#x9;&#x9;GEPRUEFT_VON,&#xD;&#xA;&#x9;&#x9;HAUPTAUFTRAGNR,&#xD;&#xA;&#x9;&#x9;GEPRUEFT_VON2,&#xD;&#xA;&#x9;&#x9;GEPRUEFT_VON3,&#xD;&#xA;&#x9;&#x9;WV_STATUS&#xD;&#xA;FROM&#x9;stg.s_innosoft_angkopfz  angkopfz&#xD;&#xA;LEFT JOIN&#xD;&#xA;(SELECT angnr,&#xD;&#xA;                          Max(aindex) AS max_aindex&#xD;&#xA;                   FROM   stg.s_innosoft_angkopfz AS angkopfz&#xD;&#xA;                          WHERE angnr in (SELECT angnr&#xD;&#xA;                                      FROM   stg.s_innosoft_angkopfz AS&#xD;&#xA;                                             s_innosoft_angkopfz_1&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  WHERE status = 'A' &#xD;&#xA;                                      GROUP  BY angnr&#xD;&#xA;                                      HAVING ( Count(angnr) > 1 )) &#xD;&#xA;                   GROUP  BY angnr) AS tab&#xD;&#xA;               ON angkopfz.angnr = tab.angnr&#xD;&#xA;                  AND angkopfz.aindex &lt;> tab.max_aindex &#xD;&#xA;&#xD;&#xA;&quot;"/>
