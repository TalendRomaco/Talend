  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="240" posY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="//Prüfe, ob der erste eines Jahres ist und eine neue EOY-Tabelle aufgebaut werden muss&#xA;&#xA;&#xA;Date today = TalendDate.getCurrentDate();&#xA;&#xA;&#xA;String actYear = TalendDate.formatDate(&quot;yyyy&quot;, today);&#xA;String prevYear = TalendDate.formatDate(&quot;yyyy&quot;, TalendDate.addDate(today,-1,&quot;yyyy&quot;));&#xA;String prevPrevYear = TalendDate.formatDate(&quot;yyyy&quot;, TalendDate.addDate(today,-2,&quot;yyyy&quot;));&#xA;int isFirstDayOfYear = 0;&#xA;&#xA;if(TalendDate.formatDate(&quot;dd.MM&quot;, today).equals(&quot;01.01&quot;))&#xA;{&#xA;isFirstDayOfYear = 1;&#xA;System.out.println(&quot;##########################&quot;);&#xA;System.out.println(&quot;Die aktuellen EOY-Tabellen werden mit einem Postfix vom letzten Jahr (&quot;+prevYear+&quot;) versehen.&quot;);&#xA;System.out.println(&quot;Für die im letzten Jahr aufgebauten EOY-Tabellen wird das entsprechende Postfix (&quot;+actYear+&quot;) entfernt.&quot;);&#xA;System.out.println(&quot;Es werden neue EOY-Tabellen für das aktuelle Jahr werden mit entsprechendem Postfix (&quot;+actYear+&quot;) aufgebaut.&quot;);&#xA;System.out.println(&quot;##########################&quot;);&#xA;}else{&#xA;isFirstDayOfYear = 0;&#xA;System.out.println(&quot;##########################&quot;);&#xA;System.out.println(&quot;Die EOY-Tabellen für das aktuelle Jahr werden weiterhin mit einem entsprechendem Postfix (&quot;+actYear+&quot;) aufgebaut.&quot;);&#xA;System.out.println(&quot;##########################&quot;);&#xA;}&#xA;&#xA;&#xA;&#xA;globalMap.put(&quot;actYear&quot;, actYear);&#xA;globalMap.put(&quot;prevYear&quot;, prevYear);&#xA;globalMap.put(&quot;prevPrevYear&quot;, prevPrevYear);&#xA;globalMap.put(&quot;isFirstDayOfYear&quot;, isFirstDayOfYear);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Berechne / Printout&#xD;&#xA;Parameter"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="352" posY="512">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_3" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="String eoyTableActYear = &quot;EOY_&quot;+(String)globalMap.get(&quot;table&quot;)+&quot;_&quot;+(String)globalMap.get(&quot;actYear&quot;);&#xA;&#xA;System.out.println(&quot;&quot;);&#xA;System.out.println(&quot;##########################&quot;);&#xA;System.out.println(&quot;Aktuell wird die folgende Tabelle betrachtet: &quot; + (String)globalMap.get(&quot;table&quot;));&#xA;&#xA;System.out.println(&quot;Speicherung unter der Sicherung des aktuellen Jahres unter: &quot; + eoyTableActYear);&#xA;System.out.println(&quot;##########################&quot;);&#xA;&#xA;globalMap.put(&quot;eoyTableActYear&quot;, eoyTableActYear);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <elementParameter field="MEMO" name="COMMENT" value="Erstelle Tabellennamen,&#xD;&#xA;Printout"/>
    <metadata connector="FLOW" name="tJava_3"/>
  </node>
  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="672" posY="512">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_4" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="String eoyTable = &quot;EOY_&quot;+(String)globalMap.get(&quot;table&quot;);&#xA;String eoyTablePrevYear = &quot;EOY_&quot;+(String)globalMap.get(&quot;table&quot;)+&quot;_&quot;+(String)globalMap.get(&quot;prevYear&quot;);&#xA;String eoyTableActYear = &quot;EOY_&quot;+(String)globalMap.get(&quot;table&quot;)+&quot;_&quot;+(String)globalMap.get(&quot;actYear&quot;);&#xA;String eoyTablePrevPrevYear = &quot;EOY_&quot;+(String)globalMap.get(&quot;table&quot;)+&quot;_&quot;+(String)globalMap.get(&quot;prevPrevYear&quot;);&#xA;&#xA;&#xA;globalMap.put(&quot;eoyTable&quot;, eoyTable);&#xA;globalMap.put(&quot;eoyTablePrevYear&quot;, eoyTablePrevYear);&#xA;globalMap.put(&quot;eoyTableActYear&quot;, eoyTableActYear);&#xA;globalMap.put(&quot;eoyTablePrevPrevYear&quot;, eoyTablePrevPrevYear);&#xA;&#xA;System.out.println(&quot;##########################&quot;);&#xA;System.out.println(&quot;Aktuell wird die folgende Tabelle betrachtet: &quot; + (String)globalMap.get(&quot;table&quot;));&#xA;&#xA;System.out.println(&quot;&quot;);&#xA;System.out.println(&quot;Erstellung neuer EOY-Tabelle für das aktuelles Jahr unter &quot; + eoyTableActYear);&#xA;System.out.println(&quot;Erstellung der der EOY-Tabelle aus &quot; + eoyTablePrevYear);&#xA;System.out.println(&quot;Aktivierung bisheriger EOY-Tabelle unter &quot; + eoyTablePrevPrevYear);&#xA;System.out.println(&quot;##########################&quot;);"/>
