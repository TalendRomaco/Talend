    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:4oaeuhIwUu5f/fz7cs2m+7k6jQGF1Eah9yz86w0W" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="context.TARGET_TABLE"/>
    <elementParameter field="CHECK" name="IDENTITY_INSERT" value="false"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;INSERT INTO DWH.PRS.&quot;+context.TARGET_TABLE+&quot;&#xD;&#xA;&#xD;&#xA;SELECT        STG.S_SAP_VBAK.VBELN AS ORDER_ID, &#xD;&#xA;&#x9;&#x9;&#x9;  PRS.F_SAP_PRODUCTION_BOOKING.BOOKING_DATE, &#xD;&#xA;&#x9;&#x9;&#x9;  dbo.UMLAUT(dbo.InitCap(STG.S_SAP42_ADRP.NAME_LAST + ' ' + STG.S_SAP42_ADRP.NAME_FIRST)) AS EMPLOYEE_NAME, &#xD;&#xA;              ROUND(CASE WHEN PRS.F_SAP_PRODUCTION_BOOKING.UNIT = 'MIN' THEN PRS.F_SAP_PRODUCTION_BOOKING.TIME / 60 ELSE PRS.F_SAP_PRODUCTION_BOOKING.TIME END, 2) AS HOURS, &#xD;&#xA;              PRS.F_SAP_PRODUCTION_BOOKING.VORNR,&#xD;&#xA;&#x9;&#x9;&#x9;  STG.S_SAP_PA0001.BUKRS AS PLANT_ID,&#xD;&#xA;&#x9;&#x9;&#x9;  PRS.F_SAP_PRODUCTION_BOOKING.PRODUCTION_ORDER_ID,&#xD;&#xA;&#x9;&#x9;&#x9;  STG.S_SAP_VBAK.SPART AS LINE_OF_BUSINESS, &#xD;&#xA;              CASE WHEN PROCESSTYPE_DE IS NULL THEN 'Fertigungsauftrag' ELSE PROCESSTYPE_DE END AS ORDER_TYPE,&#xD;&#xA;&#x9;&#x9;&#x9;  PRS.F_SAP_PRODUCTION_BOOKING.WORKING_PROCESS,&#xD;&#xA;&#x9;&#x9;&#x9;  STG.S_SAP_PA0001.PERNR AS EMPLOYEE_ID,&#xD;&#xA;              PRS.F_SAP_PRODUCTION_BOOKING.COSTCENTER_ID,&#xD;&#xA;&#x9;&#x9;&#x9;  STG.S_SAP_VBAK.ZZEQUNR_K AS MACHINE_ID,&#xD;&#xA;&#x9;&#x9;&#x9;  STG.S_SAP42_ADR6.SMTP_ADDR AS EMAIL,&#xD;&#xA;&#x9;&#x9;&#x9;  PRS.F_SAP_PRODUCTION_BOOKING.CONFIRMATION_ID, &#xD;&#xA;              PRS.F_SAP_PRODUCTION_BOOKING.CREATION_DATE,&#xD;&#xA;&#x9;&#x9;&#x9;  PRS.F_SAP_PRODUCTION_BOOKING.MATERIAL_ID,&#xD;&#xA;&#x9;&#x9;&#x9;  STG.S_SAP_VBAK.KUNNR AS CUSTOMER_ID,&#xD;&#xA;&#x9;&#x9;&#x9;  'Produktionsauftragsbuchung' AS BOOKING_TYPE,&#xD;&#xA;&#x9;&#x9;&#x9;  PRS.F_SAP_PRODUCTION_BOOKING.ACTIVITYTYPE&#xD;&#xA;FROM            PRS.D_SAP_PROCESSTYPE &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;RIGHT OUTER JOIN STG.S_SAP_VBAK ON PRS.D_SAP_PROCESSTYPE.PROCESSTYPE = STG.S_SAP_VBAK.AUART&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;LEFT OUTER JOIN STG.S_SAP_KNA1 ON STG.S_SAP_VBAK.KUNNR = STG.S_SAP_KNA1.KUNNR&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;LEFT OUTER JOIN STG.S_SAP_EQKT ON STG.S_SAP_VBAK.ZZEQUNR_K = STG.S_SAP_EQKT.EQUNR&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;RIGHT OUTER JOIN STG.S_SAP42_ADRP&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;LEFT OUTER JOIN STG.S_SAP42_ADR6 ON STG.S_SAP42_ADRP.PERSNUMBER = STG.S_SAP42_ADR6.PERSNUMBER&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;RIGHT OUTER JOIN PRS.F_SAP_PRODUCTION_BOOKING&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;LEFT OUTER JOIN STG.S_SAP_AFPO ON PRS.F_SAP_PRODUCTION_BOOKING.PRODUCTION_ORDER_ID = STG.S_SAP_AFPO.AUFNR&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;LEFT OUTER JOIN STG.S_SAP_PA0001 ON PRS.F_SAP_PRODUCTION_BOOKING.EMPLOYEE_ID = STG.S_SAP_PA0001.PERNR ON dbo.UMLAUT(STG.S_SAP42_ADRP.NAME_TEXT) = dbo.UMLAUT(STG.S_SAP_PA0001.ENAME) ON &#xD;&#xA;                         STG.S_SAP_VBAK.VBELN = STG.S_SAP_AFPO.KDAUF&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
