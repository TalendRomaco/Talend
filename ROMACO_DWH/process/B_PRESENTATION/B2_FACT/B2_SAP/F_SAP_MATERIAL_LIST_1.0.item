  <node componentName="tMSSqlRow" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="-280" posY="400">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBRow_2" show="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tMSSqlConnection_1"/>
    <elementParameter field="CLOSED_LIST" name="DRIVER" value="MSSQL_PROP" show="false"/>
    <elementParameter field="TEXT" name="HOST" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="PORT" value="&quot;1433&quot;" show="false"/>
    <elementParameter field="TEXT" name="DB_SCHEMA" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="DBNAME" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="TYPE" value="MSSQL" show="false"/>
    <elementParameter field="TEXT" name="USER" value="&quot;&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:4oaeuhIwUu5f/fz7cs2m+7k6jQGF1Eah9yz86w0W" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="context.TARGET_TABLE"/>
    <elementParameter field="CHECK" name="IDENTITY_INSERT" value="false"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;&#xD;&#xA;/*Filterung auf BOM/Stückliste Kategory != K (Basis Tabelle STKO)*/&#xD;&#xA;WITH [CTE_VALID_FROM] AS&#xD;&#xA;(&#xD;&#xA;           SELECT     [STKO].*&#xD;&#xA;           FROM       dwh.stg.[s_sap_stko] [STKO]&#xD;&#xA;           INNER JOIN&#xD;&#xA;                      (&#xD;&#xA;                                      SELECT DISTINCT([STLNR]) ,&#xD;&#xA;                                                      last_value([STLTY]) OVER (partition BY [STLNR] ORDER BY [DATUV] rows BETWEEN UNBOUNDED PRECEDING AND             UNBOUNDED following) AS [STLTY]&#xD;&#xA;                                      FROM            dwh.stg.[s_sap_stko] [STKO]&#xD;&#xA;                                      WHERE           [STLTY] != 'K' ) [VALID]&#xD;&#xA;           ON         [VALID].[STLNR] = [STKO].[STLNR]&#xD;&#xA;           AND        [VALID].[STLTY] = [STKO].[STLTY] ), &#xD;&#xA;/*Aufbau Material-/Stückliste als Full-Hierachy Struktur */&#xD;&#xA;material_list AS&#xD;&#xA;(&#xD;&#xA;           SELECT     [MAST_1].[WERKS] AS [Plant_Id],&#xD;&#xA;                      [MAST_1].[MATNR] AS [Material_Id],&#xD;&#xA;                      [MAST_1].[STLNR] AS [Material_List_Level1_No],&#xD;&#xA;                      [STPO_1].[IDNRK] AS [Material_Level1_Id],&#xD;&#xA;                      [STPO_1].[MENGE] AS [Material_Level1_Quantity],&#xD;&#xA;                      stko_1.stlst     AS material_list_status_level1,&#xD;&#xA;                      stko_1.datuv     AS valid_from_level1,&#xD;&#xA;                      stko_1.valid_to  AS valid_to_level1,&#xD;&#xA;                      [MAST_2].[STLNR] AS [Material_List_Level2_No],&#xD;&#xA;                      [STPO_2].[IDNRK] AS [Material_Level2_Id],&#xD;&#xA;                      [STPO_2].[MENGE] AS [Material_Level2_Quantity],&#xD;&#xA;                      stko_2.stlst     AS material_list_status_level2,&#xD;&#xA;                      stko_2.datuv     AS valid_from_level2,&#xD;&#xA;                      stko_2.valid_to  AS valid_to_level2,&#xD;&#xA;                      [MAST_3].[STLNR] AS [Material_List_Level3_No],&#xD;&#xA;                      [STPO_3].[IDNRK] AS [Material_Level3_Id],&#xD;&#xA;                      [STPO_3].[MENGE] AS [Material_Level3_Quantity],&#xD;&#xA;                      stko_3.stlst     AS material_list_status_level3,&#xD;&#xA;                      stko_3.datuv     AS valid_from_level3,&#xD;&#xA;                      stko_3.valid_to  AS valid_to_level3,&#xD;&#xA;                      [MAST_4].[STLNR] AS [Material_List_Level4_No],&#xD;&#xA;                      [STPO_4].[IDNRK] AS [Material_Level4_Id],&#xD;&#xA;                      [STPO_4].[MENGE] AS [Material_Level4_Quantity],&#xD;&#xA;                      stko_4.stlst     AS material_list_status_level4,&#xD;&#xA;                      stko_4.datuv     AS valid_from_level4,&#xD;&#xA;                      stko_4.valid_to  AS valid_to_level4,&#xD;&#xA;                      [MAST_5].[STLNR] AS [Material_List_Level5_No],&#xD;&#xA;                      [STPO_5].[IDNRK] AS [Material_Level5_Id],&#xD;&#xA;                      [STPO_5].[MENGE] AS [Material_Level5_Quantity],&#xD;&#xA;                      stko_5.stlst     AS material_list_status_level5,&#xD;&#xA;                      stko_5.datuv     AS valid_from_level5,&#xD;&#xA;                      stko_5.valid_to  AS valid_to_level5,&#xD;&#xA;                      [MAST_6].[STLNR] AS [Material_List_Level6_No],&#xD;&#xA;                      [STPO_6].[IDNRK] AS [Material_Level6_Id],&#xD;&#xA;                      [STPO_6].[MENGE] AS [Material_Level6_Quantity],&#xD;&#xA;                      stko_6.stlst     AS material_list_status_level6,&#xD;&#xA;                      stko_6.datuv     AS valid_from_level6,&#xD;&#xA;                      stko_6.valid_to  AS valid_to_level6,&#xD;&#xA;                      [MAST_7].[STLNR] AS [Material_List_Level7_No],&#xD;&#xA;                      [STPO_7].[IDNRK] AS [Material_Level7_Id],&#xD;&#xA;                      [STPO_7].[MENGE] AS [Material_Level7_Quantity],&#xD;&#xA;                      stko_7.stlst     AS material_list_status_level7,&#xD;&#xA;                      stko_7.datuv     AS valid_from_level7,&#xD;&#xA;                      stko_7.valid_to  AS valid_to_level7&#xD;&#xA;           FROM       dwh.stg.[s_sap_mast] [MAST_1]&#xD;&#xA;           INNER JOIN [CTE_VALID_FROM] [STKO_1]&#xD;&#xA;           ON         [MAST_1].[STLNR] = [STKO_1].[STLNR]&#xD;&#xA;           AND        [MAST_1].[STLAL] = [STKO_1].[STLAL]&#xD;&#xA;           INNER JOIN dwh.stg.[s_sap_stpo] [STPO_1]&#xD;&#xA;           ON         [STKO_1].[STLNR] = [STPO_1].[STLNR]&#xD;&#xA;           AND        [STKO_1].[STLTY] = [STPO_1].[STLTY]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_mast] [MAST_2]&#xD;&#xA;           ON         [MAST_2].[MATNR] = [STPO_1].[IDNRK]&#xD;&#xA;           AND        [MAST_2].[WERKS] = [MAST_1].[WERKS]&#xD;&#xA;           LEFT JOIN  [CTE_VALID_FROM] [STKO_2]&#xD;&#xA;           ON         [MAST_2].[STLNR] = [STKO_2].[STLNR]&#xD;&#xA;           AND        [MAST_2].[STLAL] = [STKO_2].[STLAL]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_stpo] [STPO_2]&#xD;&#xA;           ON         [STKO_2].[STLNR] = [STPO_2].[STLNR]&#xD;&#xA;           AND        [STKO_2].[STLTY] = [STPO_2].[STLTY]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_mast] [MAST_3]&#xD;&#xA;           ON         [MAST_3].[MATNR] = [STPO_2].[IDNRK]&#xD;&#xA;           AND        [MAST_3].[WERKS] = [MAST_2].[WERKS]&#xD;&#xA;           LEFT JOIN  [CTE_VALID_FROM] [STKO_3]&#xD;&#xA;           ON         [MAST_3].[STLNR] = [STKO_3].[STLNR]&#xD;&#xA;           AND        [MAST_3].[STLAL] = [STKO_3].[STLAL]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_stpo] [STPO_3]&#xD;&#xA;           ON         [STKO_3].[STLNR] = [STPO_3].[STLNR]&#xD;&#xA;           AND        [STKO_3].[STLTY] = [STPO_3].[STLTY]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_mast] [MAST_4]&#xD;&#xA;           ON         [MAST_4].[MATNR] = [STPO_3].[IDNRK]&#xD;&#xA;           AND        [MAST_4].[WERKS] = [MAST_3].[WERKS]&#xD;&#xA;           LEFT JOIN  [CTE_VALID_FROM] [STKO_4]&#xD;&#xA;           ON         [MAST_4].[STLNR] = [STKO_4].[STLNR]&#xD;&#xA;           AND        [MAST_4].[STLAL] = [STKO_4].[STLAL]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_stpo] [STPO_4]&#xD;&#xA;           ON         [STKO_4].[STLNR] = [STPO_4].[STLNR]&#xD;&#xA;           AND        [STKO_4].[STLTY] = [STPO_4].[STLTY]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_mast] [MAST_5]&#xD;&#xA;           ON         [MAST_5].[MATNR] = [STPO_4].[IDNRK]&#xD;&#xA;           AND        [MAST_5].[WERKS] = [MAST_4].[WERKS]&#xD;&#xA;           LEFT JOIN  [CTE_VALID_FROM] [STKO_5]&#xD;&#xA;           ON         [MAST_5].[STLNR] = [STKO_5].[STLNR]&#xD;&#xA;           AND        [MAST_5].[STLAL] = [STKO_5].[STLAL]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_stpo] [STPO_5]&#xD;&#xA;           ON         [STKO_5].[STLNR] = [STPO_5].[STLNR]&#xD;&#xA;           AND        [STKO_5].[STLTY] = [STPO_5].[STLTY]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_mast] [MAST_6]&#xD;&#xA;           ON         [MAST_6].[MATNR] = [STPO_5].[IDNRK]&#xD;&#xA;           AND        [MAST_6].[WERKS] = [MAST_5].[WERKS]&#xD;&#xA;           LEFT JOIN  [CTE_VALID_FROM] [STKO_6]&#xD;&#xA;           ON         [MAST_6].[STLNR] = [STKO_6].[STLNR]&#xD;&#xA;           AND        [MAST_6].[STLAL] = [STKO_6].[STLAL]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_stpo] [STPO_6]&#xD;&#xA;           ON         [STKO_6].[STLNR] = [STPO_6].[STLNR]&#xD;&#xA;           AND        [STKO_6].[STLTY] = [STPO_6].[STLTY]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_mast] [MAST_7]&#xD;&#xA;           ON         [MAST_7].[MATNR] = [STPO_6].[IDNRK]&#xD;&#xA;           AND        [MAST_7].[WERKS] = [MAST_6].[WERKS]&#xD;&#xA;           LEFT JOIN  [CTE_VALID_FROM] [STKO_7]&#xD;&#xA;           ON         [MAST_7].[STLNR] = [STKO_7].[STLNR]&#xD;&#xA;           AND        [MAST_7].[STLAL] = [STKO_7].[STLAL]&#xD;&#xA;           LEFT JOIN  dwh.stg.[s_sap_stpo] [STPO_7]&#xD;&#xA;           ON         [STKO_7].[STLNR] = [STPO_7].[STLNR]&#xD;&#xA;           AND        [STKO_7].[STLTY] = [STPO_7].[STLTY])&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;/*Erstellung Material-/Stückliste als Parent-Child Struktur auf Basis der Full-Hierachy Struktur und Import in Tabelle*/&#xD;&#xA;INSERT INTO DWH.PRS.&quot;+context.TARGET_TABLE+&quot;&#xD;&#xA;&#xD;&#xA;SELECT DISTINCT PLANT_ID,&#xD;&#xA;                PLANT_ID + '_' + ROOT_MATERIAL_ID AS ROOT_MATERIAL_TID,&#xD;&#xA;                ROOT_MATERIAL_ID,&#xD;&#xA;                PLANT_ID + '_' + PARENT_MATERIAL_ID AS PARENT_MATERIAL_TID,&#xD;&#xA;                PARENT_MATERIAL_ID,&#xD;&#xA;                PLANT_ID + '_' + MATERIAL_ID AS MATERIAL_TID,&#xD;&#xA;                MATERIAL_ID,&#xD;&#xA;                MATERIAL_LIST_LEVEL,&#xD;&#xA;                QUANTITY,&#xD;&#xA;                MATERIAL_LIST_STATUS,&#xD;&#xA;                VALID_FROM,&#xD;&#xA;                VALID_TO&#xD;&#xA;           &#xD;&#xA;FROM            (&#xD;&#xA;                       SELECT 1 AS material_list_level,&#xD;&#xA;                              plant_id,&#xD;&#xA;                              material_id                 AS root_material_id,&#xD;&#xA;                              material_id                 AS parent_material_id,&#xD;&#xA;                              material_level1_id          AS material_id,&#xD;&#xA;                              material_level1_quantity    AS quantity,&#xD;&#xA;                              material_list_status_level1 AS material_list_status,&#xD;&#xA;                              valid_from_level1           AS valid_from,&#xD;&#xA;                              valid_to_level1             AS valid_to&#xD;&#xA;                       FROM   material_list&#xD;&#xA;                       UNION ALL&#xD;&#xA;                       SELECT 2 AS material_list_level,&#xD;&#xA;                              plant_id,&#xD;&#xA;                              material_id                 AS root_material_id,&#xD;&#xA;                              material_level1_id          AS parent_material_id,&#xD;&#xA;                              material_level2_id          AS material_id,&#xD;&#xA;                              material_level2_quantity    AS quantity,&#xD;&#xA;                              material_list_status_level2 AS material_list_status,&#xD;&#xA;                              valid_from_level2           AS valid_from,&#xD;&#xA;                              valid_to_level2             AS valid_to&#xD;&#xA;                       FROM   material_list&#xD;&#xA;                       UNION ALL&#xD;&#xA;                       SELECT 3 AS material_list_level,&#xD;&#xA;                              plant_id,&#xD;&#xA;                              material_id                 AS root_material_id,&#xD;&#xA;                              material_level2_id          AS parent_material_id,&#xD;&#xA;                              material_level3_id          AS material_id,&#xD;&#xA;                              material_level3_quantity    AS quantity,&#xD;&#xA;                              material_list_status_level3 AS material_list_status,&#xD;&#xA;                              valid_from_level3           AS valid_from,&#xD;&#xA;                              valid_to_level3             AS valid_to&#xD;&#xA;                       FROM   material_list&#xD;&#xA;                       UNION ALL&#xD;&#xA;                       SELECT 4 AS material_list_level,&#xD;&#xA;                              plant_id,&#xD;&#xA;                              material_id                 AS root_material_id,&#xD;&#xA;                              material_level3_id          AS parent_material_id,&#xD;&#xA;                              material_level4_id          AS material_id,&#xD;&#xA;                              material_level4_quantity    AS quantity,&#xD;&#xA;                              material_list_status_level4 AS material_list_status,&#xD;&#xA;                              valid_from_level4           AS valid_from,&#xD;&#xA;                              valid_to_level4             AS valid_to&#xD;&#xA;                       FROM   material_list&#xD;&#xA;                       UNION ALL&#xD;&#xA;                       SELECT 5 AS material_list_level,&#xD;&#xA;                              plant_id,&#xD;&#xA;                              material_id                 AS root_material_id,&#xD;&#xA;                              material_level4_id          AS parent_material_id,&#xD;&#xA;                              material_level5_id          AS material_id,&#xD;&#xA;                              material_level5_quantity    AS quantity,&#xD;&#xA;                              material_list_status_level5 AS material_list_status,&#xD;&#xA;                              valid_from_level5           AS valid_from,&#xD;&#xA;                              valid_to_level5             AS valid_to&#xD;&#xA;                       FROM   material_list&#xD;&#xA;                       UNION ALL&#xD;&#xA;                       SELECT 6 AS material_list_level,&#xD;&#xA;                              plant_id,&#xD;&#xA;                              material_id                 AS root_material_id,&#xD;&#xA;                              material_level5_id          AS parent_material_id,&#xD;&#xA;                              material_level6_id          AS material_id,&#xD;&#xA;                              material_level6_quantity    AS quantity,&#xD;&#xA;                              material_list_status_level6 AS material_list_status,&#xD;&#xA;                              valid_from_level6           AS valid_from,&#xD;&#xA;                              valid_to_level6             AS valid_to&#xD;&#xA;                       FROM   material_list ) tab&#xD;&#xA;WHERE           material_id IS NOT NULL&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
