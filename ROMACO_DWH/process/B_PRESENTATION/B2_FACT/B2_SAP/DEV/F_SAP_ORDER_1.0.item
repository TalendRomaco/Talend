    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT MANDT,&#xD;&#xA;&#x9;&#x9;VBELN as DOCUMENT_NUMBER_ID,&#xD;&#xA;&#x9;&#x9;POSNR,&#xD;&#xA;&#x9;&#x9;MATNR,&#xD;&#xA;&#x9;&#x9;MATWA,&#xD;&#xA;&#x9;&#x9;LGORT,&#xD;&#xA;&#x9;&#x9;SPART,&#xD;&#xA;&#x9;&#x9;NETWR AS NET_VALUE,&#xD;&#xA;&#x9;&#x9;CMTD_DELIV_DATE,&#xD;&#xA;&#x9;&#x9;KWMENG,&#xD;&#xA;&#x9;&#x9;LSMENG,&#xD;&#xA;&#x9;&#x9;KBMENG,&#xD;&#xA;&#x9;&#x9;KLMENG,&#xD;&#xA;&#x9;&#x9;LFGSA,&#xD;&#xA;&#x9;&#x9;GBSTA,&#xD;&#xA;&#x9;&#x9;WAERK as CURRENCY_ID,&#xD;&#xA;&#x9;&#x9;AUFNR,&#xD;&#xA;&#x9;&#x9;WKTNR,&#xD;&#xA;&#x9;&#x9;WKTPS&#xD;&#xA;FROM&#x9;stg.s_sap_vbap&#xD;&#xA;WHERE LEFT(VBELN,1) NOT IN (2,5) &#xD;&#xA;AND MATNR = '50RKA9125V'&#xD;&#xA;&quot;"/>
