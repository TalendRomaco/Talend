    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;INSERT INTO DWH.PRS.&quot;+context.TARGET_TABLE + &quot;&#xD;&#xA;&#xD;&#xA;SELECT &#x9;ML.PLANT_ID,&#xD;&#xA;                &#x9;&#x9;ROOT_MATERIAL_TID,&#xD;&#xA;                &#x9;&#x9;ROOT_MATERIAL_ID,&#xD;&#xA;                &#x9;&#x9;PARENT_MATERIAL_TID,&#xD;&#xA;                &#x9;&#x9;PARENT_MATERIAL_ID,&#xD;&#xA;                &#x9;&#x9;MATERIAL_TID,&#xD;&#xA;                &#x9;&#x9;MATERIAL_ID,&#xD;&#xA;                        ML.MATERIAL_LIST_LEVEL,&#xD;&#xA;                        ML.QUANTITY AS MATERIAL_LIST_QUANTITY,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ML.MATERIAL_LIST_STATUS,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ML.VALID_FROM AS MATERIAL_LIST_VALID_FROM,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ML.VALID_TO AS MATERIAL_LIST_VALID_TO,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;CASE &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN GETDATE() BETWEEN ML.VALID_FROM AND ML.VALID_TO THEN 'JA' &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ELSE 'NEIN' END AS MATERIAL_LIST_IS_VALID,&#x9;&#x9;&#x9; &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; &#xD;&#xA;                         EINA.LIFNR AS VENDOR_ID,&#xD;&#xA;                         CASE WHEN(EINA.RELIF='X') THEN 'MAIN VENDOR' &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN EINA.LIFNR IS NULL THEN NULL &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ELSE 'SECONDARY VENDOR' END AS VENDOR_TYPE,&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; &#x9;&#x9;&#x9;&#x9;&#x9;&#x9; &#xD;&#xA;                         KONM.KSTBM AS BULK_QUANTIY,&#xD;&#xA;                         KONM.KBETR AS BULK_PRICE,&#xD;&#xA;                         A017.DATAB AS BULK_VALID_FROM,&#xD;&#xA;                         A017.DATBI AS BULK_VALID_TO,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; &#xD;&#xA;                         CASE&#xD;&#xA;                           WHEN EINE.NETPR = 0 THEN CONDITION.PREIS&#xD;&#xA;                           ELSE EINE.NETPR END AS CONDITION,&#xD;&#xA;                         CASE&#xD;&#xA;                           WHEN EINE.NETPR = 0 THEN CONDITION.BWAER&#xD;&#xA;                           ELSE EINE.WAERS END AS CONDITION_CURRENCY,&#xD;&#xA;                         CASE&#xD;&#xA;                           WHEN EINE.NETPR = 0 THEN CONDITION.PEINH&#xD;&#xA;                           ELSE EINE.PEINH&#xD;&#xA;                         END AS CONDITION_AMOUNT,&#xD;&#xA;                         CASE&#xD;&#xA;                           WHEN EINE.NETPR = 0 THEN CONDITION.BPRME&#xD;&#xA;                           ELSE EINE.BPRME&#xD;&#xA;                         END AS CONDITION_UNIT,&#xD;&#xA;                         EINE.PRDAT AS CONDITION_VALID_TO,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; CASE WHEN GETDATE() BETWEEN A017.DATAB AND A017.DATBI THEN 'JA' &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN (A017.DATAB IS NULL AND A017.DATBI IS NULL) AND (GETDATE() &lt;= EINE.PRDAT OR EINE.PRDAT IS NULL) THEN 'JA' &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ELSE 'NEIN' END AS BULK_CONDITION_IS_VALID,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;    ML.QUANTITY&#xD;&#xA;&#xD;&#xA;FROM   &#xD;&#xA;&#x9;/*MATERIAL LISTE &amp; STÜCKLISTE */&#xD;&#xA;&#x9;PRS.F_SAP_MATERIAL_LIST ML&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;/*STAMMDATENINFORMATION WIE PURCHASE_GROUP*/&#xD;&#xA;    INNER JOIN STG.S_SAP_MARC MARC&#xD;&#xA;                                ON ML.MATERIAL_ID = MARC.MATNR&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AND ML.PLANT_ID = MARC.WERKS&#xD;&#xA;&#x9;&#xD;&#xA;  /*Informationen zum Lieferanten und der Staffel über eINA, A017, KONP, KONM*/&#x9;&#x9;&#x9;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;LEFT JOIN STG.S_SAP_EINA EINA&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ON EINA.MATNR = ML.MATERIAL_ID&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;LEFT JOIN STG.S_SAP_A017 A017&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ON A017.MATNR = ML.MATERIAL_ID&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AND A017.LIFNR = EINA.LIFNR&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;LEFT JOIN STG.S_SAP_KONP KONP &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ON KONP.KNUMH = A017.KNUMH&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;LEFT JOIN STG.S_SAP_KONM KONM&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ON KONM.KNUMH = A017.KNUMH&#xD;&#xA;&#x9;/*Informationen zu Konditionen*/&#x9;&#x9;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;LEFT JOIN &#xD;&#xA;&#x9;&#x9;(SELECT&#x9;                         EIPA.INFNR,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; PEINH,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; BPRME,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; BWAER,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; PREIS&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;FROM   STG.S_SAP_EIPA EIPA&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;   INNER JOIN (SELECT INFNR,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  MAX(BEDAT) AS BEDAT&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   FROM   STG.S_SAP_EIPA&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   GROUP  BY INFNR) MAX_EIPA&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   ON MAX_EIPA.INFNR = EIPA.INFNR&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  AND MAX_EIPA.BEDAT = EIPA.BEDAT) AS CONDITION&#xD;&#xA;&#x9;&#x9;ON EINA.INFNR = CONDITION.INFNR&#x9;&#x9;&#x9;&#x9;  &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;  &#xD;&#xA;       LEFT JOIN STG.S_SAP_EINE EINE&#xD;&#xA;                     ON EINA.INFNR = EINE.INFNR&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
