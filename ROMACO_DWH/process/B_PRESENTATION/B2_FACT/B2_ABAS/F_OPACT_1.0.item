    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &#xD;&#xA;&#xD;&#xA;&#x9;&#x9;\&quot;ID\&quot;,&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;KOSN,&#xD;&#xA;&#x9;&#x9;KOSUCH,&#xD;&#xA;&#x9;&#x9;GJAHR,&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;S1,&#xD;&#xA;&#x9;&#x9;S2,&#xD;&#xA;&#x9;&#x9;S3,&#xD;&#xA;&#x9;&#x9;S4,&#xD;&#xA;&#x9;&#x9;S5,&#xD;&#xA;&#x9;&#x9;S6,&#xD;&#xA;&#x9;&#x9;S7,&#xD;&#xA;&#x9;&#x9;S8,&#xD;&#xA;&#x9;&#x9;S9,&#xD;&#xA;&#x9;&#x9;S10,&#xD;&#xA;&#x9;&#x9;S11,&#xD;&#xA;&#x9;&#x9;S12,&#xD;&#xA;&#x9;&#x9;S13,&#xD;&#xA;&#x9;&#x9;S14,&#xD;&#xA;&#x9;&#x9;S15,&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;H1,&#xD;&#xA;&#x9;&#x9;H2,&#xD;&#xA;&#x9;&#x9;H3,&#xD;&#xA;&#x9;&#x9;H4,&#xD;&#xA;&#x9;&#x9;H5,&#xD;&#xA;&#x9;&#x9;H6,&#xD;&#xA;&#x9;&#x9;H7,&#xD;&#xA;&#x9;&#x9;H8,&#xD;&#xA;&#x9;&#x9;H9,&#xD;&#xA;&#x9;&#x9;H10,&#xD;&#xA;&#x9;&#x9;H11,&#xD;&#xA;&#x9;&#x9;H12,&#xD;&#xA;&#x9;&#x9;H13,&#xD;&#xA;&#x9;&#x9;H14,&#xD;&#xA;&#x9;&#x9;H15,&#xD;&#xA;&#x9;&#x9;M1,&#xD;&#xA;&#x9;&#x9;M2,&#xD;&#xA;&#x9;&#x9;M3,&#xD;&#xA;&#x9;&#x9;M4,&#xD;&#xA;&#x9;&#x9;M5,&#xD;&#xA;&#x9;&#x9;M6,&#xD;&#xA;&#x9;&#x9;M7,&#xD;&#xA;&#x9;&#x9;M8,&#xD;&#xA;&#x9;&#x9;M9,&#xD;&#xA;&#x9;&#x9;M10,&#xD;&#xA;&#x9;&#x9;M11,&#xD;&#xA;&#x9;&#x9;M12,&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;KOSTENART,&#xD;&#xA;&#x9;&#x9;KOKSTKTR,&#xD;&#xA;&#x9;&#x9;BEPLANT,&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;SN,&#xD;&#xA;&#x9;&#x9;NUMMER,&#xD;&#xA;        BUKREIS,&#xD;&#xA;        MANDANT_ID&#xD;&#xA;FROM&#x9;stg.s_abas_EDS$Transactionfigures &#xD;&#xA;WHERE LEFT(GJAHR, 2) >= '17'  -- Only from 2017 to the future&#xD;&#xA;AND dart = '(ActCos)'&#xD;&#xA;&#xD;&#xA;&quot;"/>
