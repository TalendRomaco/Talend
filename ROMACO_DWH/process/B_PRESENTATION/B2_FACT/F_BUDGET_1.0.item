    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="Budget" expression="row1.Budget!= null ? new BigDecimal(row1.Budget.replace(&quot;,&quot;,&quot;.&quot;)) : null" type="id_BigDecimal"/>
