    <elementParameter field="TEXT" name="USER" value="&quot;sa&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:DaesqmR9YvyQyXkbDs5jEgTYbmS7SAebRs7E0u5SbNL2fDwdf9L8" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;MARA+MARC+MBEW+AUSP+CABN&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT MARA.matnr AS MATERIAL_ID,&#xD;&#xA;       MARC.werks AS PLANT_ID,&#xD;&#xA;       min(MARA.meins) AS UNIT,&#xD;&#xA;       min(MARC.ekgrp) AS PURCHASING_GROUP,&#xD;&#xA;       min(MARC.stawn) AS COMMODITY_CODE,&#xD;&#xA;       min(MBEW.verpr) AS PRICE_MOVING_AVERAGE,&#xD;&#xA;       min(MBEW.stprs) AS PRICE_MM03,&#xD;&#xA;       min(MBEW.peinh) AS PRICE_UNIT,&#xD;&#xA;       min(MBEW.laepr) AS LAST_PRICE_MODIFICATION,&#xD;&#xA;       min(case when cabn.atnam is not null then AUSP.atwrt else null end) AS MATERIAL_CHARACTERISTIC &#xD;&#xA;FROM   stg.s_sap_mara MARA&#xD;&#xA;       INNER JOIN stg.s_sap_marc MARC&#xD;&#xA;               ON MARA.matnr = MARC.matnr&#xD;&#xA;       LEFT JOIN stg.s_sap_mbew MBEW&#xD;&#xA;               ON MARC.matnr = MBEW.matnr&#xD;&#xA;                  AND MARC.werks = MBEW.bwkey&#xD;&#xA;       LEFT JOIN stg.s_sap_ausp AUSP&#xD;&#xA;               ON MARA.matnr = AUSP.objek&#xD;&#xA;&#xD;&#xA;&#x9;   LEFT JOIN stg.s_sap_cabn CABN&#xD;&#xA;               ON CABN.atinn = AUSP.atinn&#xD;&#xA;                  AND CABN.atnam LIKE 'P_KLASSE_SIEBLER'&#xD;&#xA;&#xD;&#xA;GROUP BY MARA.matnr,&#xD;&#xA;       MARC.werks&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="id_MSSQL" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;instance=mssql_Dwh&quot;" show="false"/>
    <elementParameter field="CHECK" name="ACTIVE_DIR_AUTH" value="false" show="false"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" value="&quot;ISO-8859-15&quot;" show="false"/>
    <elementParameter field="TECHNICAL" name="ENCODING:ENCODING_TYPE" value="ISO-8859-15"/>
    <elementParameter field="CHECK" name="ENABLE_ALWAYS_ENCRYPTED" value="false" show="false"/>
    <elementParameter field="TEXT" name="KEYSTORE_PRINCIPAL_ID" value="" show="false"/>
    <elementParameter field="PASSWORD" name="KEYSTORE_SECRET" value="" show="false"/>
    <elementParameter field="CHECK" name="TRIM_ALL_COLUMN" value="false"/>
    <elementParameter field="TABLE" name="TRIM_COLUMN">
      <elementValue elementRef="SCHEMA_COLUMN" value="MATERIAL_ID"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="PLANT_ID"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="UNIT"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="PURCHASING_GROUP"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="COMMODITY_CODE"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="PRICE_MOVING_AVERAGE"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="PRICE_MM03"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="PRICE_UNIT"/>
      <elementValue elementRef="TRIM" value="false"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="LAST_PRICE_MODIFICATION"/>
      <elementValue elementRef="TRIM" value="false"/>
