    <metadata connector="FLOW" name="tMSSqlInput_1">
      <column comment="" key="false" length="40" name="MATERIAL_ID" nullable="true" pattern="" precision="0" sourceType="VARCHAR" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="4" name="PLANT_ID" nullable="true" pattern="" precision="0" sourceType="VARCHAR" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="3" name="UNIT" nullable="true" pattern="" precision="0" sourceType="VARCHAR" type="id_String" originalLength="-1" usefulColumn="true"/>
