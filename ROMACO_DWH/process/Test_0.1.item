      <elementValue elementRef="TRIM" value="false"/>
    </elementParameter>
    <elementParameter field="CHECK" name="SET_QUERY_TIMEOUT" value="false"/>
    <elementParameter field="TEXT" name="QUERY_TIMEOUT_IN_SECONDS" value="30" show="false"/>
    <elementParameter field="TEXT" name="LABEL" value="__UNIQUE_NAME__&lt;br>__TABLE__&lt;br>__COMMENT__"/>
