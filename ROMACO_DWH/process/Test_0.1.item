    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;SELECT DISTINCT&#xD;&#xA;COLUMN_NAME &#xD;&#xA;FROM INFORMATION_SCHEMA.COLUMNS  a&#xD;&#xA;inner join&#xD;&#xA;adm.ADMIN_LOG_SAP_COLUMN_DEFINITON b&#xD;&#xA;on b.[COLUMN] = a.COLUMN_NAME&#xD;&#xA;and replace(a.[TABLE_NAME],'S_SAP_','')=b.[TABLE]&#xD;&#xA;WHERE DATA_TYPE in ('varchar','nvarchar') &#xD;&#xA;AND TABLE_NAME= '&quot;+context.TARGET_TABLE+&quot;' &#xD;&#xA;AND TYPE = 'D';&#xD;&#xA;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
