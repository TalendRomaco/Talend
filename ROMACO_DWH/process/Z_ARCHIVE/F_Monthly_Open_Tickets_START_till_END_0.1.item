    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT  &#xD;&#xA;STARTING_TIME,&#xD;&#xA;END_TIME,&#xD;&#xA;&#xD;&#xA;Month(STARTING_TIME) AS S_MONTH,&#xD;&#xA;Year(STARTING_TIME) AS S_YEAR,&#xD;&#xA;&#xD;&#xA;Month(END_TIME) AS E_MONTH,&#xD;&#xA;Year(END_TIME) AS E_YEAR,&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;TYP,&#xD;&#xA;&#x9;&#x9; &#xD;&#xA;&#x9;&#x9;BU,&#xD;&#xA;&#x9;&#x9; &#xD;&#xA;&#x9;&#x9;BRAND, &#xD;&#xA;        STATUS,&#xD;&#xA;&#x9;&#x9; &#xD;&#xA;   &quot; + (Integer)globalMap.get(&quot;GJahr&quot;)       + &quot; AS GJahr,&#xD;&#xA;   &quot; + (Integer)globalMap.get(&quot;GMonat&quot;)   + &quot; AS GMonat&#xD;&#xA;&#xD;&#xA;FROM&#x9;dwh.F_Ticket_Report &#xD;&#xA;WHERE Year(STARTING_TIME)  * 100 + Month(STARTING_TIME) &lt;= &quot; + (Integer)globalMap.get(&quot;MonthIndex&quot;)   + &quot;  AND &#xD;&#xA;( Year(END_TIME)  * 100 + Month(END_TIME) >  &quot; + (Integer)globalMap.get(&quot;MonthIndex&quot;)   + &quot; OR END_TIME IS NULL )  ORDER BY STARTING_TIME&quot;"/>
