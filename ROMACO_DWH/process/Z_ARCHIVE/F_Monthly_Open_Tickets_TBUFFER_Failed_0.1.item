    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT  problemnr, startzeit, endzeit, hotliner, maschnr, status,&#xD;&#xA;problemkey,&#xD;&#xA;vorgangstatus,&#xD;&#xA;&#xD;&#xA;ISNULL(&#xD;&#xA;CASE left(hotliner,3)&#xD;&#xA;           WHEN 'KA-' THEN  'Karlsruhe'&#xD;&#xA;           WHEN 'ST-' THEN 'Steinen'&#xD;&#xA;           WHEN 'BO-' THEN 'Bologna'&#xD;&#xA;           WHEN 'CO-' THEN 'Cologne'&#xD;&#xA;           ELSE NULL&#xD;&#xA;         END, 'no_group')  as HOTLINER_GROUP,&#xD;&#xA;&#x9;&#x9; &#xD;&#xA;   &quot; + (Integer)globalMap.get(&quot;GJahr&quot;)       + &quot; AS GJahr,&#xD;&#xA;   &quot; + (Integer)globalMap.get(&quot;GMonat&quot;)   + &quot; AS GMonat&#xD;&#xA;&#xD;&#xA;FROM   dwh.s_innosoft_probleme&#xD;&#xA;WHERE year(startzeit) * 100 + month(startzeit) &lt;= &quot; + (Integer)globalMap.get(&quot;MonthIndex&quot;)   + &quot;  AND &#xD;&#xA;                          ( (  year(endzeit) * 100 + month(endzeit) >  &quot; + (Integer)globalMap.get(&quot;MonthIndex&quot;)   + &quot; AND status = '9999') &#xA; OR&#xD;&#xA;                        ( status &lt;> '9999')&#xD;&#xA;                      )&#xD;&#xA;ORDER BY problemnr DESC&quot;"/>
