package routines;

import java.lang.reflect.Type;
import java.util.HashMap;
import java.util.Map;
import java.util.regex.Matcher;

import com.google.gson.Gson;
import com.google.gson.reflect.TypeToken;

public class TtaSerialization {

    public static Map<String, Object> parseAdvancedParam(String jsonString) {
    	
    	Map<String, Object> paramMap = new HashMap<String, Object>();

    	try{
    		
    		Type stringObjectMap = new TypeToken<Map<String, Object>>(){}.getType();
    		paramMap = new Gson().fromJson(jsonString, stringObjectMap);
    		
    	}catch(Exception e){
    		
    	}
    	   	
    	return paramMap;
    }
    
 	public static String fixQuotes(String jsonString) {
    	String fixedString = null;
    	
 		if(jsonString != null)
 			fixedString = jsonString.replaceAll("\"", Matcher.quoteReplacement("\\\""));
 		
 		return fixedString;
    }
    
}
